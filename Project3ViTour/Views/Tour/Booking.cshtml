@using Project3ViTour.Dtos.TourDtos
@model List<ResultTourDto>
@inject Microsoft.Extensions.Localization.IStringLocalizer<Project3ViTour.Resources.SharedResource> L
@{
    Layout = null;
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="tr" lang="tr">

@await Component.InvokeAsync("_TourHeadComponentPartial")

<body class="body header-fixed">

    <div class="preload preload-container">
        <svg class="pl" width="240" height="240" viewBox="0 0 240 240">
            <circle class="pl__ring pl__ring--a" cx="120" cy="120" r="105" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 660" stroke-dashoffset="-330" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--b" cx="120" cy="120" r="35" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 220" stroke-dashoffset="-110" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--c" cx="85" cy="120" r="70" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 440" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--d" cx="155" cy="120" r="70" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 440" stroke-linecap="round"></circle>
        </svg>
    </div>

    <div id="wrapper">
        <div id="pagee" class="clearfix">

            @await Component.InvokeAsync("_TourDetailsHeaderComponentPartial")

            <main id="main">

                <section>
                    <div class="tf-container full">
                        <div class="row">
                            <div class="col-md-12">
                                <img src="/vitour/breakcrumb2.jpg" alt="image">
                            </div>
                        </div>
                    </div>
                </section>

                <section class="booking-section" style="padding: 60px 0;">
                    <div class="tf-container">
                        <div class="row justify-content-center">

                            <!-- Sol: Form -->
                            <div class="col-lg-8">
                                <div class="booking-form-wrap" style="background:#fff; border-radius:16px; padding:40px; box-shadow: 0 4px 30px rgba(0,0,0,0.08);">

                                    <div class="booking-header mb-40" style="border-bottom: 2px solid #f0f0f0; padding-bottom: 24px;">
                                        <span style="color: var(--color-main, #2ecc71); font-weight: 600; font-size: 14px; text-transform: uppercase; letter-spacing: 2px;">@L["Nav_Booking"]</span>
                                        <h2 style="font-size: 32px; font-weight: 700; color: #1a1a2e; margin-top: 8px;">@L["Booking_Title"]</h2>
                                        <p style="color: #777; margin-top: 8px;">@L["Booking_Subtitle"]</p>
                                    </div>
                                    @if (TempData["Error"] != null)
                                    {
                                        <div style="background:#fee; border:1.5px solid #e74c3c; border-radius:10px; padding:16px 20px; margin-bottom:24px; color:#e74c3c; font-weight:600;">
                                            <i class="icon-warning"></i> @TempData["Error"]
                                        </div>
                                    }

                                    <form asp-action="Booking" asp-controller="Tour" method="post">
                                        <input type="hidden" name="TotalPrice" id="totalPrice" value="0">

                                        <div class="row">

                                            <!-- Tur Seçimi -->
                                            <div class="col-md-12 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_SelectTour"] <span style="color:red">*</span></label>
                                                <select name="TourId" id="tourSelect" required
                                                        style="width:100%; padding: 14px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s; appearance:none; background:#fff; cursor:pointer;"
                                                        onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'"
                                                        onchange="updatePrice(this)">
                                                    <option value="">@L["Booking_SelectTourPlaceholder"]</option>
                                                    @foreach (var tour in Model)
                                                    {
                                                        <option value="@tour.TourId" data-price="@tour.Price">
                                                            @tour.Title — ₺@tour.Price
                                                        </option>
                                                    }
                                                </select>
                                            </div>

                                            <!-- Fiyat Göstergesi -->
                                            <div class="col-md-12 mb-30" id="priceBox" style="display:none;">
                                                <div style="background: #f0fdf4; border: 1.5px solid #2ecc71; border-radius:10px; padding: 16px 20px; display:flex; justify-content:space-between; align-items:center;">
                                                    <span style="color:#333; font-weight:600;">@L["Booking_PricePerPerson"]:</span>
                                                    <span id="priceDisplay" style="color:#2ecc71; font-size:22px; font-weight:700;">₺0</span>
                                                </div>
                                            </div>

                                            <!-- Ad Soyad -->
                                            <div class="col-md-6 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_NameSurname"] <span style="color:red">*</span></label>
                                                <fieldset class="relative input-wrap">
                                                    <i class="icon-user-1-1"></i>
                                                    <input type="text" name="NameSurname" placeholder="@L["Booking_NameSurname"]" required
                                                           style="width:100%; padding: 14px 14px 14px 45px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s;"
                                                           onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'">
                                                </fieldset>
                                            </div>

                                            <!-- Email -->
                                            <div class="col-md-6 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_Email"] <span style="color:red">*</span></label>
                                                <fieldset class="relative input-wrap">
                                                    <i class="icon-Group-51"></i>
                                                    <input type="email" name="Email" placeholder="ornek@email.com" required
                                                           style="width:100%; padding: 14px 14px 14px 45px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s;"
                                                           onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'">
                                                </fieldset>
                                            </div>

                                            <!-- Telefon -->
                                            <div class="col-md-6 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_Phone"] <span style="color:red">*</span></label>
                                                <fieldset class="relative input-wrap">
                                                    <i class="icon-phone"></i>
                                                    <input type="tel" name="Phone" placeholder="+90 5xx xxx xx xx" required
                                                           style="width:100%; padding: 14px 14px 14px 45px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s;"
                                                           onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'">
                                                </fieldset>
                                            </div>

                                            <!-- Kişi Sayısı -->
                                            <div class="col-md-6 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_GuestCount"] <span style="color:red">*</span></label>
                                                <fieldset class="relative input-wrap">
                                                    <i class="icon-user"></i>
                                                    <input type="number" name="GuestCount" id="guestCount" placeholder="@L["Booking_GuestCount"]" min="1" required
                                                           style="width:100%; padding: 14px 14px 14px 45px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s;"
                                                           onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'"
                                                           oninput="calcTotal()">
                                                </fieldset>
                                            </div>

                                            <!-- Tarih -->
                                            <div class="col-md-12 mb-30">
                                                <label style="font-weight:600; color:#333; margin-bottom:8px; display:block;">@L["Booking_Date"] <span style="color:red">*</span></label>
                                                <fieldset class="relative input-wrap">
                                                    <i class="icon-time-left"></i>
                                                    <input type="date" name="BookingDate" required
                                                           style="width:100%; padding: 14px 14px 14px 45px; border: 1.5px solid #e0e0e0; border-radius: 10px; font-size:15px; transition: border 0.3s;"
                                                           onfocus="this.style.borderColor='#2ecc71'" onblur="this.style.borderColor='#e0e0e0'">
                                                </fieldset>
                                            </div>

                                            <!-- Toplam -->
                                            <div class="col-md-12 mb-30" id="totalBox" style="display:none;">
                                                <div style="background: #1a1a2e; border-radius:10px; padding: 16px 20px; display:flex; justify-content:space-between; align-items:center;">
                                                    <span style="color:#fff; font-weight:600;">@L["Booking_Total"]:</span>
                                                    <span id="totalDisplay" style="color:#2ecc71; font-size:24px; font-weight:700;">₺0</span>
                                                </div>
                                            </div>

                                            <!-- Şartlar -->
                                            <div class="col-md-12 mb-30">
                                                <div class="checkbox">
                                                    <input id="terms" type="checkbox" required>
                                                    <label for="terms" style="color:#555;">@L["Booking_TermsAccept"]</label>
                                                </div>
                                            </div>

                                            <div class="col-md-12">
                                                <button type="submit"
                                                        style="width:100%; padding: 16px; background: var(--color-main, #2ecc71); color:#fff; border:none; border-radius:10px; font-size:16px; font-weight:700; cursor:pointer; transition: opacity 0.3s;"
                                                        onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                                                    @L["Booking_Submit"]
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <!-- Sağ: Bilgi -->
                            <div class="col-lg-4">
                                <div class="booking-info-wrap" style="position: sticky; top: 100px;">
                                    <div class="sidebar-widget" style="background:#fff; border-radius:16px; padding:30px; box-shadow: 0 4px 30px rgba(0,0,0,0.08); margin-bottom:24px;">
                                        <h6 class="block-heading" style="margin-bottom:20px;">@L["Detail_BookWithConfidence"]</h6>
                                        <ul class="category-confidence">
                                            <li class="flex-three" style="margin-bottom:14px;"><i class="icon-customer-service-1"></i><span>@L["Detail_CustomerCare"]</span></li>
                                            <li class="flex-three" style="margin-bottom:14px;"><i class="icon-Vector-6"></i><span>@L["Detail_HandpickedTours"]</span></li>
                                            <li class="flex-three" style="margin-bottom:14px;"><i class="icon-insurance-1"></i><span>@L["Detail_FreeInsurance"]</span></li>
                                            <li class="flex-three"><i class="icon-price-tag-1-1"></i><span>@L["Detail_BestPrice"]</span></li>
                                        </ul>
                                    </div>
                                    <div class="sidebar-widget" style="background: linear-gradient(135deg, #2ecc71, #27ae60); border-radius:16px; padding:30px; color:#fff;">
                                        <h6 style="color:#fff; margin-bottom:16px; font-size:16px; font-weight:700;">@L["Booking_CancelPolicy"]</h6>
                                        <ul style="list-style:none; padding:0; margin:0;">
                                            <li style="margin-bottom:10px; display:flex; gap:8px; align-items:flex-start;"><i class="icon-Vector-7" style="color:#fff; margin-top:3px;"></i><span style="font-size:14px;">Tur tarihinden 7 gün önce ücretsiz iptal</span></li>
                                            <li style="margin-bottom:10px; display:flex; gap:8px; align-items:flex-start;"><i class="icon-Vector-7" style="color:#fff; margin-top:3px;"></i><span style="font-size:14px;">3-7 gün arası %50 iade</span></li>
                                            <li style="display:flex; gap:8px; align-items:flex-start;"><i class="icon-Vector-7" style="color:#fff; margin-top:3px;"></i><span style="font-size:14px;">3 günden az iade yapılmaz</span></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </section>

            </main>

            @await Component.InvokeAsync("_TourFooterComponentPartial")
        </div>
    </div>

    @await Component.InvokeAsync("_TourScriptComponentPartial")

    <script>
        var selectedPrice = 0;
        function updatePrice(select) {
            var option = select.options[select.selectedIndex];
            selectedPrice = parseFloat(option.getAttribute('data-price')) || 0;
            if (selectedPrice > 0) {
                document.getElementById('priceBox').style.display = 'block';
                document.getElementById('priceDisplay').innerText = '₺' + selectedPrice.toLocaleString('tr-TR');
            } else {
                document.getElementById('priceBox').style.display = 'none';
            }
            calcTotal();
        }
        function calcTotal() {
            var guest = parseInt(document.getElementById('guestCount').value) || 0;
            var total = selectedPrice * guest;
            document.getElementById('totalPrice').value = total;
            if (total > 0) {
                document.getElementById('totalBox').style.display = 'block';
                document.getElementById('totalDisplay').innerText = '₺' + total.toLocaleString('tr-TR');
            } else {
                document.getElementById('totalBox').style.display = 'none';
            }
        }
    </script>

</body>
</html>
