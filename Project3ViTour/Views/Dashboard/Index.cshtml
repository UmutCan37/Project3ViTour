@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pulse-ring {
            0% {
                transform: scale(1);
                opacity: .6;
            }

            70% {
                transform: scale(1.6);
                opacity: 0;
            }

            100% {
                transform: scale(1.6);
                opacity: 0;
            }
        }

        .fade-up {
            animation: fadeUp .55s cubic-bezier(.4,0,.2,1) both;
        }

        .d1 {
            animation-delay: .05s
        }

        .d2 {
            animation-delay: .10s
        }

        .d3 {
            animation-delay: .15s
        }

        .d4 {
            animation-delay: .20s
        }

        .d5 {
            animation-delay: .25s
        }

        .d6 {
            animation-delay: .30s
        }

        .d7 {
            animation-delay: .35s
        }

        .d8 {
            animation-delay: .40s
        }

        /* Welcome Banner */
        .welcome-banner {
            background: linear-gradient(135deg, var(--dark) 0%, #1a3d1a 60%, #2ecc71 140%);
            border-radius: 20px;
            padding: 28px 32px;
            position: relative;
            overflow: hidden;
            color: #fff;
        }

            .welcome-banner::before {
                content: '';
                position: absolute;
                top: -60px;
                right: -60px;
                width: 260px;
                height: 260px;
                background: radial-gradient(circle, rgba(46,204,113,.25) 0%, transparent 70%);
                border-radius: 50%;
            }

            .welcome-banner::after {
                content: '';
                position: absolute;
                bottom: -80px;
                right: 140px;
                width: 180px;
                height: 180px;
                background: radial-gradient(circle, rgba(46,204,113,.12) 0%, transparent 70%);
                border-radius: 50%;
            }

        .welcome-title {
            font-family: 'Fraunces',serif;
            font-size: 26px;
            font-weight: 700;
            margin: 0 0 6px;
            line-height: 1.2;
        }

        .welcome-sub {
            font-size: 13.5px;
            opacity: .7;
            margin: 0;
        }

        .welcome-date {
            font-size: 12px;
            opacity: .55;
            margin-top: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .welcome-orb {
            position: absolute;
            right: 32px;
            top: 50%;
            transform: translateY(-50%);
            width: 72px;
            height: 72px;
            background: rgba(46,204,113,.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
            border: 1.5px solid rgba(46,204,113,.3);
        }

            .welcome-orb i {
                font-size: 30px;
                color: var(--green);
            }

        /* Stat Cards */
        .stat-card {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: 18px;
            padding: 22px 22px 18px;
            box-shadow: var(--shadow-sm);
            transition: all .22s cubic-bezier(.4,0,.2,1);
            position: relative;
            overflow: hidden;
            cursor: default;
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg,var(--green),var(--green-dk));
                opacity: 0;
                transition: opacity .22s;
            }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
                border-color: var(--green-mid);
            }

                .stat-card:hover::before {
                    opacity: 1;
                }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            background: var(--green-lt);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            position: relative;
        }

            .stat-icon i {
                font-size: 20px;
                color: var(--green);
            }

            .stat-icon .pulse {
                position: absolute;
                inset: 0;
                border-radius: 14px;
                border: 2px solid var(--green);
                animation: pulse-ring 2.5s ease-out infinite;
            }

        .stat-value {
            font-size: 30px;
            font-weight: 800;
            color: var(--dark);
            line-height: 1;
            font-family: 'Fraunces',serif;
        }

        .stat-label {
            font-size: 12.5px;
            color: var(--text-muted);
            font-weight: 500;
            margin-top: 2px;
        }

        .stat-change {
            font-size: 11.5px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 3px;
        }

            .stat-change.up {
                background: rgba(46,204,113,.12);
                color: var(--green-dk);
            }

            .stat-change.neu {
                background: var(--surface);
                color: var(--text-muted);
            }

        .sparkline-wrap {
            height: 40px;
            margin-top: 12px;
            display: flex;
            align-items: flex-end;
            gap: 3px;
        }

        .spark-bar {
            flex: 1;
            border-radius: 4px 4px 0 0;
            background: var(--green-mid);
            min-height: 4px;
        }

            .spark-bar.active {
                background: var(--green);
            }

        /* Section */
        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .section-title {
            font-family: 'Fraunces',serif;
            font-size: 17px;
            color: var(--dark);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-title i {
                color: var(--green);
                font-size: 16px;
            }

        .section-link {
            font-size: 12.5px;
            font-weight: 600;
            color: var(--green-dk);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: gap .15s;
        }

            .section-link:hover {
                gap: 8px;
                color: var(--green-dk);
            }

        /* Recent Table */
        .recent-table th {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-muted);
            background: var(--surface);
            padding: 11px 16px;
            border-bottom: 1.5px solid var(--border) !important;
        }

        .recent-table td {
            padding: 13px 16px;
            font-size: 13.5px;
            vertical-align: middle;
            border-bottom: 1px solid var(--border) !important;
        }

        .recent-table tr:last-child td {
            border-bottom: none !important;
        }

        .recent-table tr:hover td {
            background: var(--green-lt);
        }

        .avatar-sm {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: linear-gradient(135deg,var(--green),var(--green-dk));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(46,204,113,.3);
        }

        /* Quick Actions */
        .quick-action {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 14px;
            border: 1.5px solid var(--border);
            background: var(--white);
            text-decoration: none;
            color: var(--text-main);
            transition: all .18s;
        }

            .quick-action:hover {
                border-color: var(--green);
                background: var(--green-lt);
                transform: translateX(4px);
                color: var(--text-main);
            }

        .qa-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--green-lt);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .qa-icon i {
                font-size: 17px;
                color: var(--green);
            }

        .qa-label {
            font-size: 13.5px;
            font-weight: 600;
        }

        .qa-sub {
            font-size: 11.5px;
            color: var(--text-muted);
        }

        /* Activity Feed */
        .activity-item {
            display: flex;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }

            .activity-item:last-child {
                border-bottom: none;
            }

        .act-dot {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        /* Progress */
        .prog-wrap {
            height: 6px;
            background: var(--green-lt);
            border-radius: 999px;
            overflow: hidden;
        }

        .prog-fill {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg,var(--green),var(--green-dk));
        }

        @@media (max-width:767px) {
            .welcome-orb {
                display: none;
            }

            .welcome-title {
                font-size: 20px;
            }
        }
    </style>
}

@{
    int tourCount = ViewBag.TourCount ?? 0;
    int bookingCount = ViewBag.BookingCount ?? 0;
    int locationCount = ViewBag.LocationCount ?? 0;
    int categoryCount = ViewBag.CategoryCount ?? 0;
    int galleryCount = ViewBag.GalleryCount ?? 0;
    int planningCount = ViewBag.PlanningCount ?? 0;
    double avgRating = ViewBag.AvgRating ?? 0.0;

    var lastBookings = ViewBag.LastBookings as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var lastReviews = ViewBag.LastReviews as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var tourDict = ViewBag.TourDict as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<!-- Welcome Banner -->
<div class="welcome-banner fade-up d1 mb-4">
    <div class="welcome-orb"><i class="bi bi-compass-fill"></i></div>
    <p class="welcome-sub">Hoş geldiniz 👋</p>
    <h1 class="welcome-title">ViTour Yönetim Paneli</h1>
    <div class="welcome-date">
        <i class="bi bi-calendar3"></i>
        <span id="currentDate"></span>
        &nbsp;·&nbsp;
        <i class="bi bi-circle-fill" style="font-size:6px;color:var(--green);"></i>
        &nbsp;Sistem aktif
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card fade-up d2">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon">
                    <div class="pulse"></div>
                    <i class="bi bi-map-fill"></i>
                </div>
                <span class="stat-change up"><i class="bi bi-arrow-up-short"></i>Tur</span>
            </div>
            <div class="stat-value" data-target="@tourCount">0</div>
            <div class="stat-label">Toplam Tur</div>
            <div class="sparkline-wrap">
                <div class="spark-bar" style="height:40%"></div>
                <div class="spark-bar" style="height:55%"></div>
                <div class="spark-bar" style="height:45%"></div>
                <div class="spark-bar" style="height:70%"></div>
                <div class="spark-bar" style="height:60%"></div>
                <div class="spark-bar" style="height:80%"></div>
                <div class="spark-bar active" style="height:100%"></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card fade-up d3">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon"><i class="bi bi-calendar2-check-fill"></i></div>
                <span class="stat-change up"><i class="bi bi-arrow-up-short"></i>Rezervasyon</span>
            </div>
            <div class="stat-value" data-target="@bookingCount">0</div>
            <div class="stat-label">Toplam Rezervasyon</div>
            <div class="sparkline-wrap">
                <div class="spark-bar" style="height:50%"></div>
                <div class="spark-bar" style="height:65%"></div>
                <div class="spark-bar" style="height:55%"></div>
                <div class="spark-bar" style="height:75%"></div>
                <div class="spark-bar" style="height:85%"></div>
                <div class="spark-bar" style="height:70%"></div>
                <div class="spark-bar active" style="height:100%"></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card fade-up d4">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon"><i class="bi bi-star-fill"></i></div>
                <span class="stat-change up"><i class="bi bi-arrow-up-short"></i>Puan</span>
            </div>
            <div class="stat-value" data-target="@avgRating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" data-decimal="true">0</div>
            <div class="stat-label">Ortalama Puan</div>
            <div class="sparkline-wrap">
                <div class="spark-bar" style="height:80%"></div>
                <div class="spark-bar" style="height:85%"></div>
                <div class="spark-bar" style="height:78%"></div>
                <div class="spark-bar" style="height:90%"></div>
                <div class="spark-bar" style="height:88%"></div>
                <div class="spark-bar" style="height:92%"></div>
                <div class="spark-bar active" style="height:96%"></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card fade-up d5">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="stat-icon"><i class="bi bi-geo-alt-fill"></i></div>
                <span class="stat-change neu">Lokasyon</span>
            </div>
            <div class="stat-value" data-target="@locationCount">0</div>
            <div class="stat-label">Toplam Lokasyon</div>
            <div class="sparkline-wrap">
                <div class="spark-bar" style="height:60%"></div>
                <div class="spark-bar" style="height:60%"></div>
                <div class="spark-bar" style="height:70%"></div>
                <div class="spark-bar" style="height:70%"></div>
                <div class="spark-bar" style="height:80%"></div>
                <div class="spark-bar" style="height:80%"></div>
                <div class="spark-bar active" style="height:100%"></div>
            </div>
        </div>
    </div>
</div>

<!-- Main Row -->
<div class="row g-4 mb-4">
    <!-- Son Rezervasyonlar -->
    <div class="col-lg-8">
        <div class="card fade-up d5">
            <div class="card-header">
                <div class="section-head mb-0">
                    <div class="section-title">
                        <i class="bi bi-calendar2-check-fill"></i> Son Rezervasyonlar
                    </div>
                    <a href="/Booking/Index" class="section-link">Tümünü gör <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (!lastBookings.Any())
                {
                    <div class="text-center py-4" style="color:var(--text-muted);">
                        <i class="bi bi-calendar2 " style="font-size:32px;opacity:.3;"></i>
                        <p class="mt-2 mb-0" style="font-size:13px;">Henüz rezervasyon yok</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table recent-table mb-0">
                            <thead>
                                <tr>
                                    <th>Müşteri</th>
                                    <th>Tur</th>
                                    <th>Tarih</th>
                                    <th>Kişi</th>
                                    <th>Tutar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in lastBookings)
                                {
                                    string nameSurname = b.NameSurname?.ToString() ?? "—";
                                    string initials = nameSurname.Length >= 2
                                    ? nameSurname.Substring(0, 1).ToUpper() + nameSurname.Split(' ').LastOrDefault()?.Substring(0, 1).ToUpper()
                                    : nameSurname.Substring(0, 1).ToUpper();
                                    string tourName = tourDict.ContainsKey(b.TourId?.ToString() ?? "")
                                    ? tourDict[b.TourId.ToString()] : (b.TourId?.ToString() ?? "—");
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-sm">@initials</div>
                                                <div>
                                                    <div style="font-weight:600;font-size:13px;">@nameSurname</div>
                                                    <div style="font-size:11px;color:var(--text-muted);">@b.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span style="font-weight:600;font-size:13px;">@tourName</span></td>
                                        <td><span style="font-size:12.5px;color:var(--text-muted);">@b.BookingDate.ToString("dd MMM yyyy")</span></td>
                                        <td><span class="badge-green">@b.GuestCount kişi</span></td>
                                        <td><span style="font-weight:700;color:var(--green-dk);">₺@b.TotalPrice.ToString("N0")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sağ Kolon -->
    <div class="col-lg-4 d-flex flex-column gap-4">
        <!-- Hızlı İşlemler -->
        <div class="card fade-up d6">
            <div class="card-header">
                <div class="section-title">
                    <i class="bi bi-lightning-fill"></i> Hızlı İşlemler
                </div>
            </div>
            <div class="card-body p-3 d-flex flex-column gap-2">
                <a href="/AdminTour/TourList" class="quick-action">
                    <div class="qa-icon"><i class="bi bi-map-fill"></i></div>
                    <div><div class="qa-label">Turlar</div><div class="qa-sub">Tur listesini yönet</div></div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--text-muted);font-size:12px;"></i>
                </a>
                <a href="/Location/Index" class="quick-action">
                    <div class="qa-icon"><i class="bi bi-geo-alt-fill"></i></div>
                    <div><div class="qa-label">Lokasyonlar</div><div class="qa-sub">Lokasyon yönetimi</div></div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--text-muted);font-size:12px;"></i>
                </a>
                <a href="/GalleryImage/Index" class="quick-action">
                    <div class="qa-icon"><i class="bi bi-images"></i></div>
                    <div><div class="qa-label">Galeri</div><div class="qa-sub">Görsel yönetimi</div></div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--text-muted);font-size:12px;"></i>
                </a>
                <a href="/Review/ReviewList" class="quick-action">
                    <div class="qa-icon"><i class="bi bi-star-fill"></i></div>
                    <div><div class="qa-label">Yorumlar</div><div class="qa-sub">Müşteri yorumları</div></div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--text-muted);font-size:12px;"></i>
                </a>
                <a href="/TourPlanning/Index" class="quick-action">
                    <div class="qa-icon"><i class="bi bi-journal-text"></i></div>
                    <div><div class="qa-label">Tur Planları</div><div class="qa-sub">Gün planı yönetimi</div></div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--text-muted);font-size:12px;"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Alt Row -->
<div class="row g-4">
    <!-- Son Yorumlar -->
    <div class="col-lg-6">
        <div class="card fade-up d7">
            <div class="card-header">
                <div class="section-head mb-0">
                    <div class="section-title">
                        <i class="bi bi-star-fill"></i> Son Yorumlar
                    </div>
                    <a href="/Review/ReviewList" class="section-link">Tümü <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="card-body p-4">
                @if (!lastReviews.Any())
                {
                    <div class="text-center py-3" style="color:var(--text-muted);">
                        <i class="bi bi-star" style="font-size:28px;opacity:.3;"></i>
                        <p class="mt-2 mb-0" style="font-size:13px;">Henüz yorum yok</p>
                    </div>
                }
                else
                {
                    @foreach (var r in lastReviews)
                    {
                        string rTourName = tourDict.ContainsKey(r.TourId?.ToString() ?? "")
                        ? tourDict[r.TourId.ToString()] : (r.TourId?.ToString() ?? "—");
                        <div class="activity-item">
                            <div class="act-dot" style="background:var(--green-lt);border:1.5px solid var(--green-mid);">
                                <i class="bi bi-person-fill" style="color:var(--green);font-size:13px;"></i>
                            </div>
                            <div style="flex:1;min-width:0;">
                                <div class="d-flex align-items-center justify-content-between">
                                    <span style="font-weight:700;font-size:13px;color:var(--text-main);">@r.NameSurname</span>
                                    <div>
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <i class="bi bi-star-fill" style="font-size:10px;color:@(s <= (int)r.Score ? "#f59e0b" : "var(--border)");"></i>
                                        }
                                    </div>
                                </div>
                                <div style="font-size:11.5px;color:var(--green-dk);font-weight:600;margin:2px 0;">@rTourName</div>
                                <div style="font-size:12px;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@r.Detail</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Sistem Özeti -->
    <div class="col-lg-6">
        <div class="card fade-up d8">
            <div class="card-header">
                <div class="section-title">
                    <i class="bi bi-grid-1x2-fill"></i> Sistem Özeti
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @{
                        var summaryItems = new[]
                        {
                    new { Icon="bi-tag-fill",     Label="Kategoriler",  Val=categoryCount, Href="/Category/CategoryList" },
                    new { Icon="bi-images",       Label="Galeri",       Val=galleryCount,  Href="/GalleryImage/Index" },
                    new { Icon="bi-journal-text", Label="Tur Planları", Val=planningCount, Href="/TourPlanning/Index" },
                    new { Icon="bi-geo-alt-fill", Label="Lokasyonlar",  Val=locationCount, Href="/Location/Index" },
                    };
                    }
                    @foreach (var item in summaryItems)
                    {
                        <div class="col-6">
                            <a href="@item.Href" style="text-decoration:none;">
                                <div class="stat-card" style="padding:16px;">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:38px;height:38px;background:var(--green-lt);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="bi @item.Icon" style="color:var(--green);font-size:15px;"></i>
                                        </div>
                                        <div>
                                            <div class="stat-value" style="font-size:22px;" data-target="@item.Val">0</div>
                                            <div style="font-size:11.5px;color:var(--text-muted);font-weight:500;">@item.Label</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tarih
        document.getElementById('currentDate').textContent =
            new Date().toLocaleDateString('tr-TR', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

        // Sayaç animasyonu
        document.querySelectorAll('.stat-value[data-target]').forEach(el => {
            const target   = parseFloat(el.dataset.target);
            const decimal  = el.dataset.decimal === 'true';
            const duration = 1200;
            const start    = performance.now();
            function tick(now) {
                const p    = Math.min((now - start) / duration, 1);
                const ease = 1 - Math.pow(1 - p, 3);
                el.textContent = decimal ? (target * ease).toFixed(1) : Math.floor(target * ease);
                if (p < 1) requestAnimationFrame(tick);
                else el.textContent = decimal ? target.toFixed(1) : target;
            }
            requestAnimationFrame(tick);
        });
    </script>
}
