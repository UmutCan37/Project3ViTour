@model Project3ViTour.Dtos.ReviewDtos.GetReviewByIdDto
@{
    ViewData["Title"] = "UpdateReview";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}




@section Styles {
    <style>
        .form-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow-sm);
        }

        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-main);
        }

        .form-control, .form-select {
            border-radius: 10px;
            border-color: var(--border);
            padding: 10px 14px;
            font-size: 14px;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(45,156,219,.15);
            }

        .icon-box {
            width: 42px;
            height: 42px;
            background: var(--navy);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            color: var(--navy);
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 18px;
        }

        .star-filled {
            color: #f59e0b;
        }

        .star-empty {
            color: var(--border);
        }
    </style>
}

<div class="page-header mb-4">
    <h1 class="page-title">Yorum Güncelle</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Home/Index" style="color:var(--accent);">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Review/Index" style="color:var(--accent);">Yorumlar</a></li>
            <li class="breadcrumb-item active">Güncelle</li>
        </ol>
    </nav>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="form-card p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="icon-box">
                    <i class="bi bi-pencil-fill" style="color:var(--accent); font-size:18px;"></i>
                </div>
                <div>
                    <h5 class="mb-0" style="font-family:'Playfair Display',serif; color:var(--navy);">Yorum Bilgileri</h5>
                    <small style="color:var(--text-muted);">Yorum bilgilerini güncelleyin</small>
                </div>
            </div>

            <form asp-action="UpdateReview" asp-controller="Review" method="post">
                <input asp-for="ReviewId" type="hidden" />

                <div class="section-title"><i class="bi bi-person me-2" style="color:var(--accent);"></i>Müşteri Bilgisi</div>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-person-fill me-1" style="color:var(--accent);"></i>Ad Soyad</label>
                    <input asp-for="NameSurname" class="form-control" />
                </div>

                <div class="section-title"><i class="bi bi-chat-left-text me-2" style="color:var(--accent);"></i>Yorum Detayı</div>
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-text-left me-1" style="color:var(--accent);"></i>Yorum</label>
                    <textarea asp-for="Detail" class="form-control" rows="4"></textarea>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label"><i class="bi bi-star-fill me-1" style="color:#f59e0b;"></i>Puan</label>
                        <select asp-for="Score" class="form-select">
                            <option value="1">1 ⭐</option>
                            <option value="2">2 ⭐⭐</option>
                            <option value="3">3 ⭐⭐⭐</option>
                            <option value="4">4 ⭐⭐⭐⭐</option>
                            <option value="5">5 ⭐⭐⭐⭐⭐</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label"><i class="bi bi-calendar-fill me-1" style="color:var(--accent);"></i>Tarih</label>
                        <input asp-for="ReviewDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label"><i class="bi bi-toggle-on me-1" style="color:var(--accent);"></i>Durum</label>
                        <select asp-for="Status" class="form-select">
                            <option value="true">Aktif</option>
                            <option value="false">Pasif</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label"><i class="bi bi-map-fill me-1" style="color:var(--accent);"></i>Tour ID</label>
                    <input asp-for="TourId" class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn" style="background:var(--accent); color:#fff; border-radius:10px; padding:10px 28px; font-weight:600; border:none;">
                        <i class="bi bi-check-lg me-1"></i> Güncelle
                    </button>
                    <a href="/Review/Index" class="btn" style="background:var(--surface); color:var(--text-muted); border-radius:10px; padding:10px 24px; border:1px solid var(--border);">
                        İptal
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="form-card p-4">
            <div class="section-title"><i class="bi bi-info-circle me-2" style="color:var(--accent);"></i>Yorum Özeti</div>
            <div class="d-flex flex-column gap-3">
                <div class="p-3" style="background:var(--surface); border-radius:12px;">
                    <div style="font-size:12px; color:var(--text-muted);">Müşteri</div>
                    <div style="font-weight:600; font-size:13px; color:var(--navy);">@Model.NameSurname</div>
                </div>
                <div class="p-3" style="background:var(--surface); border-radius:12px;">
                    <div style="font-size:12px; color:var(--text-muted); margin-bottom:4px;">Mevcut Puan</div>
                    @for (int s = 1; s <= 5; s++)
                    {
                        <i class="bi bi-star-fill @(s <= Model.Score ? "star-filled" : "star-empty")" style="font-size:16px;"></i>
                    }
                </div>
                <div class="p-3" style="background:var(--surface); border-radius:12px;">
                    <div style="font-size:12px; color:var(--text-muted);">Durum</div>
                    <div style="font-weight:600; font-size:13px;">
                        @if (Model.Status)
                        {
                            <span style="color:var(--success);"><i class="bi bi-check-circle-fill me-1"></i>Aktif</span>
                        }
                        else
                        {
                            <span style="color:var(--danger);"><i class="bi bi-x-circle-fill me-1"></i>Pasif</span>
                        }
                    </div>
                </div>
                <div class="p-3" style="background:var(--surface); border-radius:12px;">
                    <div style="font-size:12px; color:var(--text-muted);">Tarih</div>
                    <div style="font-weight:600; font-size:13px; color:var(--navy);">@Model.ReviewDate.ToString("dd MMMM yyyy")</div>
                </div>
            </div>
        </div>
    </div>
</div>

