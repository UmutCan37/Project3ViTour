@using Project3ViTour.Dtos.ReviewDtos
@model List<ResultReviewByTourIdDto>
@inject Microsoft.Extensions.Localization.IStringLocalizer<Project3ViTour.Resources.SharedResource> L

<div class="tab-pane fade" id="pills-reviews" role="tabpanel"
     aria-labelledby="pills-reviews-tab" tabindex="0">
    <div class="row">
        <div class="col-lg-8">
            <div class="review-content-tour">
                <div class="custom-review mb-80">
                    <h4 class="title-review mb-37">@L["Detail_CustomerReviews"]</h4>
                    <div class="flex card-list">
                        <div class="card-review">
                            <div class="percent">
                                <svg>
                                    <circle cx="105" cy="105" r="100"></circle>
                                    <circle cx="105" cy="105" r="100"
                                            style="--percent: @(Model.Any() ? Model.Average(x => x.Score) * 20 : 0)"></circle>
                                </svg>
                                <div class="number center">
                                    <span>@L["Detail_OverallRating"]</span>
                                    <h5 class="number-reating">@(Model.Any() ? Model.Average(x => x.Score).ToString("0.0") : "0.0")</h5>
                                    <span>@L["Detail_OutOf5"]</span>
                                </div>
                            </div>
                        </div>
                        <div class="review-list">
                            <div class="review-list-item mb-40">
                                <span class="comfort">@L["Detail_Reviews"]</span>
                                <div class="flex-two">
                                    <span class="reating">@Model.Count() @L["TourList_Reviews"]</span>
                                    <div class="start">
                                        <i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i>
                                    </div>
                                </div>
                                <div class="progress" role="progressbar" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar" style="width: @(Model.Any() ? Model.Average(x => x.Score) * 20 : 0)%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="client-review mb-80">
                    <div class="flex-two mb-50 inner-header">
                        <h4 class="title-review">@L["Detail_ClientReviews"]</h4>
                        <div class="client-review flex">
                            <span>@Model.Count() @L["TourList_Reviews"]</span>
                            <div class="start">
                                <i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i>
                            </div>
                            <span>(@(Model.Any() ? Model.Average(x => x.Score).ToString("0.0") : "0.0") / 5 @L["Detail_OutOf5"])</span>
                        </div>
                    </div>
                    <div class="client-review-list">
                        @if (!Model.Any())
                        {
                            <p>Henüz yorum yapılmamış.</p>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <div class="client-review-item flex">
                                    
                                    <div class="content">
                                        <span class="name">@item.NameSurname</span>
                                        <p class="des">@item.Detail</p>
                                        <div class="start">
                                            @for (int i = 0; i < item.Score; i++)
                                            {
                                                <i class="icon-Star"></i>
                                            }
                                            <span>@item.Score.ToString("0.0")</span>
                                        </div>
                                        <span class="date">@item.ReviewDate.ToString("dd MMM yyyy")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="form-review bg-1">
                    <h4 class="title-review mb-40">@L["Detail_LeaveComment"]</h4>
                    <style>
                        .star-select {
                            display: flex;
                            flex-direction: row-reverse;
                            justify-content: flex-end;
                            gap: 6px;
                            margin-bottom: 30px;
                        }

                            .star-select input {
                                display: none;
                            }

                            .star-select label {
                                font-size: 36px;
                                color: #ccc;
                                cursor: pointer;
                                transition: color 0.2s;
                            }

                                .star-select input:checked ~ label, .star-select label:hover, .star-select label:hover ~ label {
                                    color: #f5a623;
                                }
                    </style>
                    <form asp-action="CreateReview" asp-controller="Tour" method="post">
                        <input type="hidden" name="TourId" value="@ViewBag.TourId">
                        <input type="hidden" id="hiddenScore" name="Score" value="5">
                        <span style="font-weight:600; display:block; margin-bottom:10px;">Puanınız:</span>
                        <div class="star-select">
                            <input type="radio" id="s5" name="starScore" value="5"><label for="s5">&#9733;</label>
                            <input type="radio" id="s4" name="starScore" value="4"><label for="s4">&#9733;</label>
                            <input type="radio" id="s3" name="starScore" value="3"><label for="s3">&#9733;</label>
                            <input type="radio" id="s2" name="starScore" value="2"><label for="s2">&#9733;</label>
                            <input type="radio" id="s1" name="starScore" value="1"><label for="s1">&#9733;</label>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <fieldset class="relative input-wrap mb-37">
                                    <i class="icon-user-1-1"></i>
                                    <input type="text" name="NameSurname" placeholder="@L["Booking_NameSurname"]" required>
                                </fieldset>
                            </div>
                            <div class="col-lg-12">
                                <fieldset class="relative input-wrap mb-37">
                                    <i class="icon-content"></i>
                                    <textarea name="Detail" rows="6" cols="50" placeholder="@L["Detail_LeaveComment"]" required></textarea>
                                </fieldset>
                            </div>
                            <div class="col-lg-12">
                                <div class="checkbox mb-40">
                                    <input id="check-review" type="checkbox" required>
                                    <label for="check-review">@L["Booking_TermsAccept"]</label>
                                </div>
                            </div>
                            <div class="col-lg-12">
                                <button type="submit" class="submit">@L["Detail_PostComment"]</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="side-bar-right">
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookTour"]</h6>
                    <form action="/" id="form-book-tour">
                        <div class="input-wrap mb-30"><input type="date"></div>
                        <div class="flex-two mb-30">
                            <span class="label">Saat:</span>
                            <div class="radio">
                                <input id="first" type="radio" name="numbers" value="first" checked>
                                <label for="first">14.00</label>
                                <input id="second" type="radio" name="numbers" value="second">
                                <label for="second">16.00</label>
                            </div>
                        </div>
                        <div class="flex-two mb-40">
                            <span class="label">Toplam:</span>
                            <span class="total text-main">₺0.00</span>
                        </div>
                        <button type="submit">@L["Detail_ProceedBooking"]</button>
                    </form>
                </div>
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookWithConfidence"]</h6>
                    <ul class="category-confidence">
                        <li class="flex-three"><i class="icon-customer-service-1"></i><span>@L["Detail_CustomerCare"]</span></li>
                        <li class="flex-three"><i class="icon-Vector-6"></i><span>@L["Detail_HandpickedTours"]</span></li>
                        <li class="flex-three"><i class="icon-insurance-1"></i><span>@L["Detail_FreeInsurance"]</span></li>
                        <li class="flex-three"><i class="icon-price-tag-1-1"></i><span>@L["Detail_BestPrice"]</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.star-select input[type="radio"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            document.getElementById('hiddenScore').value = this.value;
        });
    });
</script>
