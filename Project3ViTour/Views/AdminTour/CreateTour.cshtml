@model CreateTourDto
@{
    ViewData["Title"] = "Yeni Tur Ekle";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        /* ─── Variables ──────────────────────────────────────── */
        :root {
            --green: #2ecc71;
            --green-dk: #27ae60;
            --green-lt: #eafaf1;
            --green-mid: #d5f5e3;
            --green-glow: rgba(46,204,113,.18);
            --surface: #f7fdf9;
            --border: #e3f2e9;
            --text-main: #1a2e1a;
            --text-muted: #7a9c7a;
            --danger: #ef4444;
            --warning: #f59e0b;
            --white: #ffffff;
        }

        /* ─── Page Header ───────────────────────────────────── */
        .section-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 28px;
        }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            color: var(--green-dk);
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .page-eyebrow::before {
                content: '';
                display: inline-block;
                width: 18px;
                height: 2px;
                background: var(--green);
                border-radius: 2px;
            }

        .page-title {
            margin: 0;
            font-family: 'Fraunces', serif;
            color: #1a2e1a;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--white);
            color: var(--text-muted);
            border: 1.5px solid var(--border);
            padding: 10px 18px;
            border-radius: 12px;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-back:hover {
                background: var(--green-lt);
                color: var(--green-dk);
                border-color: var(--green);
            }

        /* ─── Form Grid ──────────────────────────────────────── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 24px;
            align-items: start;
        }

        @@media (max-width: 1100px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ─── Form Cards ─────────────────────────────────────── */
        .form-card {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: 18px;
            box-shadow: 0 2px 16px rgba(46,204,113,.07);
            overflow: hidden;
            margin-bottom: 20px;
            transition: box-shadow .2s;
        }

            .form-card:hover {
                box-shadow: 0 4px 24px rgba(46,204,113,.13);
            }

            .form-card:last-child {
                margin-bottom: 0;
            }

        .form-card-header {
            display: flex;
            align-items: center;
            gap: 13px;
            padding: 18px 24px;
            border-bottom: 1.5px solid var(--border);
            background: linear-gradient(135deg, var(--green-lt), #f0fff4);
        }

        .form-card-icon {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .fci-green {
            background: var(--green-mid);
            color: var(--green-dk);
        }

        .fci-teal {
            background: #ccfbf1;
            color: #0f766e;
        }

        .fci-lime {
            background: #ecfccb;
            color: #4d7c0f;
        }

        .fci-emerald {
            background: #d1fae5;
            color: #065f46;
        }

        .form-card-title {
            font-size: 14.5px;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
            line-height: 1.3;
        }

        .form-card-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
        }

        .form-card-body {
            padding: 24px;
        }

        /* ─── Form Controls ──────────────────────────────────── */
        .form-label-custom {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 7px;
        }

            .form-label-custom .required {
                color: var(--danger);
                margin-left: 3px;
            }

        .form-label-hint {
            font-size: 11.5px;
            font-weight: 400;
            color: var(--text-muted);
            margin-left: 6px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 15px;
            pointer-events: none;
            z-index: 1;
        }

        .form-control-custom {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            background: var(--white);
            font-size: 13.5px;
            color: var(--text-main);
            outline: none;
            transition: all .2s;
            appearance: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

            .form-control-custom.with-icon {
                padding-left: 40px;
            }

            .form-control-custom:focus {
                border-color: var(--green);
                box-shadow: 0 0 0 3px var(--green-glow);
                background: #fafffc;
            }

            .form-control-custom.is-invalid {
                border-color: var(--danger);
                box-shadow: 0 0 0 3px rgba(239,68,68,.12);
            }

        textarea.form-control-custom {
            resize: vertical;
            min-height: 110px;
            line-height: 1.6;
        }

        .char-counter {
            text-align: right;
            font-size: 11.5px;
            color: var(--text-muted);
            margin-top: 5px;
        }

            .char-counter.warn {
                color: var(--warning);
            }

            .char-counter.limit {
                color: var(--danger);
            }

        .field-hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 6px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .field-hint i {
                font-size: 12px;
                color: var(--green);
            }

        .validation-msg {
            font-size: 12px;
            color: var(--danger);
            margin-top: 5px;
            display: none;
        }

        /* ─── Number Stepper ─────────────────────────────────── */
        .number-stepper {
            display: flex;
            align-items: center;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            background: var(--white);
            transition: all .2s;
        }

            .number-stepper:focus-within {
                border-color: var(--green);
                box-shadow: 0 0 0 3px var(--green-glow);
            }

        .stepper-btn {
            width: 42px;
            height: 46px;
            border: none;
            background: var(--green-lt);
            color: var(--green-dk);
            font-size: 17px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            flex-shrink: 0;
            user-select: none;
        }

            .stepper-btn:hover {
                background: var(--green-mid);
            }

            .stepper-btn:first-child {
                border-right: 1.5px solid var(--border);
            }

            .stepper-btn:last-child {
                border-left: 1.5px solid var(--border);
            }

        .stepper-input {
            flex: 1;
            border: none;
            outline: none;
            text-align: center;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-main);
            background: transparent;
            padding: 0 8px;
            height: 46px;
            -moz-appearance: textfield;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

            .stepper-input::-webkit-inner-spin-button,
            .stepper-input::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        /* ─── Price Input ────────────────────────────────────── */
        .price-wrapper {
            position: relative;
        }

        .price-prefix {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 46px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--green-lt);
            border-right: 1.5px solid var(--border);
            border-radius: 12px 0 0 12px;
            font-weight: 700;
            font-size: 14px;
            color: var(--green-dk);
            pointer-events: none;
            z-index: 1;
        }

        .price-input {
            padding-left: 56px !important;
        }

        /* ─── Badge Selector ─────────────────────────────────── */
        .badge-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .badge-option {
            position: relative;
        }

            .badge-option input[type="radio"] {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }

            .badge-option label {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 11px 14px;
                border: 2px solid var(--border);
                border-radius: 12px;
                cursor: pointer;
                transition: all .2s;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-main);
                user-select: none;
            }

                .badge-option label:hover {
                    border-color: var(--green);
                    background: var(--green-lt);
                }

            .badge-option input:checked + label {
                border-color: var(--green);
                background: var(--green-lt);
                box-shadow: 0 0 0 2px var(--green-glow);
            }

        .badge-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .bd-popular {
            background: #f59e0b;
        }

        .bd-new {
            background: var(--green);
        }

        .bd-limited {
            background: #ef4444;
        }

        .bd-none {
            background: #94a3b8;
        }

        /* ─── Status Toggle ──────────────────────────────────── */
        .status-toggle-wrap {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            background: var(--white);
            transition: all .2s;
            cursor: pointer;
        }

            .status-toggle-wrap:has(input:checked) {
                border-color: var(--green);
                background: var(--green-lt);
            }

        .status-toggle-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .status-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--green-lt);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: var(--text-muted);
            transition: all .2s;
        }

        .status-toggle-wrap:has(input:checked) .status-icon {
            background: var(--green-mid);
            color: var(--green-dk);
        }

        .status-label-title {
            font-size: 13.5px;
            font-weight: 700;
            color: var(--text-main);
        }

        .status-label-sub {
            font-size: 12px;
            color: var(--text-muted);
        }

        .toggle-switch {
            position: relative;
            width: 50px;
            height: 28px;
            flex-shrink: 0;
        }

            .toggle-switch input {
                display: none;
            }

        .toggle-track {
            position: absolute;
            inset: 0;
            background: #cbd5e1;
            border-radius: 14px;
            cursor: pointer;
            transition: background .25s;
        }

            .toggle-track::after {
                content: '';
                position: absolute;
                left: 3px;
                top: 3px;
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: var(--white);
                box-shadow: 0 1px 4px rgba(0,0,0,.2);
                transition: transform .25s cubic-bezier(.4,0,.2,1);
            }

        .toggle-switch input:checked + .toggle-track {
            background: var(--green);
        }

            .toggle-switch input:checked + .toggle-track::after {
                transform: translateX(22px);
            }

        /* ─── Image Preview ──────────────────────────────────── */
        .image-preview-box {
            width: 100%;
            height: 190px;
            border: 2px dashed var(--border);
            border-radius: 14px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            background: var(--green-lt);
            font-size: 13px;
            gap: 6px;
            transition: all .2s;
            overflow: hidden;
            position: relative;
            margin-bottom: 14px;
        }

            .image-preview-box.has-image {
                border-style: solid;
                border-color: var(--green);
                background: #000;
            }

            .image-preview-box img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                opacity: 0;
                transition: opacity .3s;
            }

                .image-preview-box img.loaded {
                    opacity: 1;
                }

        .preview-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            transition: opacity .2s;
        }

            .preview-placeholder i {
                font-size: 34px;
                color: var(--green-mid);
            }

        .image-preview-box.has-image .preview-placeholder {
            opacity: 0;
        }

        /* ─── Progress ───────────────────────────────────────── */
        .form-progress {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: 16px;
            padding: 18px 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 12px rgba(46,204,113,.07);
        }

        .progress-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
        }

        .progress-bar-wrap {
            height: 8px;
            background: var(--green-lt);
            border-radius: 10px;
            overflow: hidden;
        }

        #formProgressBar {
            height: 100%;
            background: linear-gradient(90deg, var(--green), #52e090);
            border-radius: 10px;
            width: 0%;
            transition: width .4s cubic-bezier(.4,0,.2,1);
        }

        /* ─── Submit Card ────────────────────────────────────── */
        .submit-card {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: 18px;
            box-shadow: 0 2px 16px rgba(46,204,113,.07);
            padding: 22px 24px;
        }

        .btn-submit {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--green), var(--green-dk));
            color: #fff;
            border: none;
            border-radius: 13px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            box-shadow: 0 4px 16px rgba(46,204,113,.35);
            margin-bottom: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(46,204,113,.45);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        .btn-cancel-submit {
            width: 100%;
            padding: 12px;
            background: none;
            color: var(--text-muted);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all .15s;
            text-align: center;
            display: block;
            text-decoration: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

            .btn-cancel-submit:hover {
                background: var(--green-lt);
                color: var(--green-dk);
                border-color: var(--green);
            }

        /* ─── Tips Card ──────────────────────────────────────── */
        .tips-card {
            background: linear-gradient(135deg, #0d2e1a 0%, #1a4a2e 100%);
            border-radius: 18px;
            padding: 22px;
            color: #fff;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
        }

            .tips-card::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 140px;
                height: 140px;
                background: rgba(46,204,113,.12);
                border-radius: 50%;
            }

        .tips-title {
            font-family: 'Fraunces', serif;
            font-size: 15px;
            color: #fff;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            position: relative;
        }

            .tips-title i {
                color: var(--green);
                font-size: 16px;
            }

        .tip-item {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            margin-bottom: 10px;
            font-size: 12.5px;
            color: rgba(255,255,255,.75);
            line-height: 1.5;
            position: relative;
        }

            .tip-item:last-child {
                margin-bottom: 0;
            }

            .tip-item i {
                font-size: 13px;
                color: var(--green);
                flex-shrink: 0;
                margin-top: 1px;
            }

        @@media (max-width: 576px) {
            .badge-selector {
                grid-template-columns: 1fr 1fr;
            }

            .form-card-body {
                padding: 16px;
            }
        }
    </style>
}

<!-- ═══ PAGE HEADER ═══════════════════════════════════════════════════ -->
<div class="section-header">
    <div>
        <p class="page-eyebrow">Tur Yönetimi</p>
        <h1 class="page-title">Yeni Tur Ekle</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Dashboard/Index" class="text-muted">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/AdminTour/TourList" class="text-muted">Turlar</a></li>
                <li class="breadcrumb-item active text-muted">Yeni Tur</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminTour/TourList" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Listeye Dön
    </a>
</div>

<!-- ═══ FORM ══════════════════════════════════════════════════════════ -->
<form method="post" id="createTourForm" novalidate>
    @Html.AntiForgeryToken()
    <div class="form-grid">

        <!-- ══ LEFT COLUMN ════════════════════════════════════════════ -->
        <div>
            <!-- Temel Bilgiler -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-teal"><i class="bi bi-info-circle-fill"></i></div>
                    <div>
                        <p class="form-card-title">Temel Bilgiler</p>
                        <p class="form-card-subtitle">Turun adı ve açıklaması</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="mb-4">
                        <label class="form-label-custom" for="Title">Tur Adı <span class="required">*</span></label>
                        <div class="input-wrapper">
                            <i class="bi bi-type input-icon"></i>
                            <input asp-for="Title" id="Title" class="form-control-custom with-icon"
                                   placeholder="Örn: Kapadokya Balon Turu" maxlength="100" autocomplete="off" />
                        </div>
                        <div class="char-counter" id="titleCounter">0 / 100</div>
                        <span asp-validation-for="Title" class="validation-msg" style="display:block;"></span>
                    </div>
                    <div class="mb-0">
                        <label class="form-label-custom" for="Description">
                            Tur Açıklaması <span class="required">*</span>
                            <span class="form-label-hint">Kısa ve öz tutun</span>
                        </label>
                        <textarea asp-for="Description" id="Description" class="form-control-custom"
                                  placeholder="Tur hakkında kısa bir açıklama yazın…" maxlength="500" rows="4"></textarea>
                        <div class="char-counter" id="descCounter">0 / 500</div>
                        <span asp-validation-for="Description" class="validation-msg" style="display:block;"></span>
                    </div>
                </div>
            </div>

            <!-- Tur Detayları -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-emerald"><i class="bi bi-sliders2-vertical"></i></div>
                    <div>
                        <p class="form-card-title">Tur Detayları</p>
                        <p class="form-card-subtitle">Süre, kapasite ve fiyat bilgileri</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label class="form-label-custom" for="DayCount">Tur Süresi <span class="required">*</span></label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', -1, 1, 365)"><i class="bi bi-dash"></i></button>
                                <input asp-for="DayCount" id="DayCount" class="stepper-input" type="number" min="1" max="365" value="1" />
                                <button type="button" class="stepper-btn" onclick="stepValue('DayCount', 1, 1, 365)"><i class="bi bi-plus"></i></button>
                            </div>
                            <p class="field-hint"><i class="bi bi-info-circle"></i> Gün cinsinden süre (1–365)</p>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label-custom" for="Capacity">Kapasite <span class="required">*</span></label>
                            <div class="number-stepper">
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', -1, 1, 999)"><i class="bi bi-dash"></i></button>
                                <input asp-for="Capacity" id="Capacity" class="stepper-input" type="number" min="1" max="999" value="10" />
                                <button type="button" class="stepper-btn" onclick="stepValue('Capacity', 1, 1, 999)"><i class="bi bi-plus"></i></button>
                            </div>
                            <p class="field-hint"><i class="bi bi-info-circle"></i> Maksimum katılımcı sayısı</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label-custom" for="Price">Fiyat (₺) <span class="required">*</span></label>
                            <div class="price-wrapper">
                                <span class="price-prefix">₺</span>
                                <input asp-for="Price" id="Price" class="form-control-custom price-input"
                                       type="number" min="0" step="0.01" placeholder="0.00" />
                            </div>
                            <p class="field-hint"><i class="bi bi-info-circle"></i> Kişi başı tur ücreti</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Kapak Görseli -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-lime"><i class="bi bi-image-fill"></i></div>
                    <div>
                        <p class="form-card-title">Kapak Görseli</p>
                        <p class="form-card-subtitle">Turun vitrin fotoğrafı</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="image-preview-box" id="imagePreviewBox">
                        <img id="imagePreview" src="" alt="Görsel önizleme" />
                        <div class="preview-placeholder">
                            <i class="bi bi-image"></i>
                            <span>Görsel önizlemesi burada görünecek</span>
                        </div>
                    </div>
                    <label class="form-label-custom" for="CoverImageUrl">Görsel URL <span class="required">*</span></label>
                    <div class="input-wrapper">
                        <i class="bi bi-link-45deg input-icon"></i>
                        <input asp-for="CoverImageUrl" id="CoverImageUrl" class="form-control-custom with-icon"
                               placeholder="https://example.com/image.jpg" autocomplete="off" />
                    </div>
                    <p class="field-hint"><i class="bi bi-info-circle"></i> Geçerli bir görsel URL'i girin. Önerilen boyut: 1200×800px</p>
                    <span asp-validation-for="CoverImageUrl" class="validation-msg" style="display:block;"></span>
                </div>
            </div>
        </div>

        <!-- ══ RIGHT COLUMN ═══════════════════════════════════════════ -->
        <div>
            <!-- Progress -->
            <div class="form-progress">
                <div class="progress-title">
                    <span>Form Tamamlama</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar-wrap">
                    <div id="formProgressBar"></div>
                </div>
            </div>

            <!-- Rozet -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-green"><i class="bi bi-award-fill"></i></div>
                    <div>
                        <p class="form-card-title">Tur Rozeti</p>
                        <p class="form-card-subtitle">Öne çıkarma etiketi</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <div class="badge-selector">
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="" id="badge-none" checked />
                            <label for="badge-none"><span class="badge-dot bd-none"></span>Yok</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Popular" id="badge-popular" />
                            <label for="badge-popular"><span class="badge-dot bd-popular"></span>Popüler</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="New" id="badge-new" />
                            <label for="badge-new"><span class="badge-dot bd-new"></span>Yeni</label>
                        </div>
                        <div class="badge-option">
                            <input type="radio" asp-for="Badge" value="Limited" id="badge-limited" />
                            <label for="badge-limited"><span class="badge-dot bd-limited"></span>Sınırlı</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Yayın Durumu -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon fci-emerald"><i class="bi bi-toggle2-on"></i></div>
                    <div>
                        <p class="form-card-title">Yayın Durumu</p>
                        <p class="form-card-subtitle">Tur aktif / pasif ayarı</p>
                    </div>
                </div>
                <div class="form-card-body">
                    <label class="status-toggle-wrap" for="IsStatus">
                        <div class="status-toggle-info">
                            <div class="status-icon"><i class="bi bi-eye-slash-fill" id="statusIconInner"></i></div>
                            <div>
                                <div class="status-label-title" id="statusLabelTitle">Pasif</div>
                                <div class="status-label-sub" id="statusLabelSub">Tur listede görünmeyecek</div>
                            </div>
                        </div>
                        <div class="toggle-switch">
                            <input asp-for="IsStatus" id="IsStatus" type="checkbox" onchange="updateStatusLabel(this)" />
                            <div class="toggle-track"></div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Kaydet -->
            <div class="submit-card">
                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="bi bi-check-circle-fill"></i>
                    Turu Kaydet
                </button>
                <a href="/AdminTour/TourList" class="btn-cancel-submit">
                    <i class="bi bi-x-circle me-1"></i> İptal Et
                </a>
            </div>

            <!-- Tips -->
            <div class="tips-card">
                <div class="tips-title"><i class="bi bi-lightbulb-fill"></i>Başarılı Tur İpuçları</div>
                <div class="tip-item"><i class="bi bi-check2-circle"></i><span>Tur adını kısa, akılda kalıcı ve ilgi çekici tutun.</span></div>
                <div class="tip-item"><i class="bi bi-check2-circle"></i><span>Yüksek çözünürlüklü, yatay formatlı görseller daha iyi görünür.</span></div>
                <div class="tip-item"><i class="bi bi-check2-circle"></i><span>"Popüler" rozetini çok satılan turlara verin.</span></div>
                <div class="tip-item"><i class="bi bi-check2-circle"></i><span>Fiyatı rekabetçi tutmak rezervasyon oranını artırır.</span></div>
                <div class="tip-item"><i class="bi bi-check2-circle"></i><span>Turu kaydetmeden önce tüm bilgileri kontrol edin.</span></div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function setupCounter(inputId, counterId, max) {
            const input = document.getElementById(inputId);
            const counter = document.getElementById(counterId);
            if (!input || !counter) return;
            function update() {
                const len = input.value.length;
                counter.textContent = len + ' / ' + max;
                counter.className = 'char-counter';
                if (len > max * 0.9) counter.classList.add('warn');
                if (len >= max) counter.classList.add('limit');
            }
            input.addEventListener('input', update);
            update();
        }
        setupCounter('Title', 'titleCounter', 100);
        setupCounter('Description', 'descCounter', 500);

        function stepValue(id, delta, min, max) {
            const input = document.getElementById(id);
            let val = parseInt(input.value) || 0;
            val = Math.min(max, Math.max(min, val + delta));
            input.value = val;
            updateProgress();
        }

        const coverInput = document.getElementById('CoverImageUrl');
        const previewBox = document.getElementById('imagePreviewBox');
        const previewImg = document.getElementById('imagePreview');
        let previewTimeout;
        coverInput.addEventListener('input', () => {
            clearTimeout(previewTimeout);
            previewTimeout = setTimeout(() => {
                const url = coverInput.value.trim();
                if (!url) { previewBox.classList.remove('has-image'); previewImg.classList.remove('loaded'); return; }
                previewImg.onload  = () => { previewBox.classList.add('has-image'); previewImg.classList.add('loaded'); };
                previewImg.onerror = () => { previewBox.classList.remove('has-image'); previewImg.classList.remove('loaded'); };
                previewImg.src = url;
            }, 600);
        });

        function updateStatusLabel(cb) {
            document.getElementById('statusLabelTitle').textContent = cb.checked ? 'Aktif' : 'Pasif';
            document.getElementById('statusLabelSub').textContent   = cb.checked ? 'Tur listede görünecek' : 'Tur listede görünmeyecek';
            document.getElementById('statusIconInner').className    = cb.checked ? 'bi bi-eye-fill' : 'bi bi-eye-slash-fill';
        }

        const trackedFields = ['Title', 'Description', 'CoverImageUrl', 'Price'];
        function updateProgress() {
            let filled = 0;
            const total = trackedFields.length + 2;
            trackedFields.forEach(id => { const el = document.getElementById(id); if (el && el.value.trim().length > 0) filled++; });
            if ((parseInt(document.getElementById('DayCount').value) || 0) >= 1) filled++;
            if ((parseInt(document.getElementById('Capacity').value) || 0) >= 1) filled++;
            const pct = Math.round((filled / total) * 100);
            document.getElementById('formProgressBar').style.width = pct + '%';
            document.getElementById('progressPercent').textContent = pct + '%';
        }
        trackedFields.forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener('input', updateProgress); });
        document.getElementById('DayCount').addEventListener('input', updateProgress);
        document.getElementById('Capacity').addEventListener('input', updateProgress);
        updateProgress();

        document.getElementById('createTourForm').addEventListener('submit', function (e) {
            let valid = true;
            trackedFields.forEach(id => {
                const el = document.getElementById(id);
                if (el && !el.value.trim()) { el.classList.add('is-invalid'); valid = false; }
                else if (el) el.classList.remove('is-invalid');
            });
            const price = parseFloat(document.getElementById('Price').value);
            if (isNaN(price) || price <= 0) { document.getElementById('Price').classList.add('is-invalid'); valid = false; }
            if (!valid) { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
            else {
                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Kaydediliyor…';
            }
        });

        document.querySelectorAll('.form-control-custom').forEach(el => {
            el.addEventListener('input', () => el.classList.remove('is-invalid'));
        });
    </script>
}
