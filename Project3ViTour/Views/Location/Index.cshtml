@model List<Project3ViTour.Dtos.LocationDtos.ResultLocationDto>
@{
    ViewData["Title"] = "Lokasyonlar";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1 class="page-title">Lokasyonlar</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Dashboard/Index" style="color:var(--green);">Dashboard</a></li>
                <li class="breadcrumb-item active">Lokasyonlar</li>
            </ol>
        </nav>
    </div>
    <a href="/Location/CreateLocation" class="btn-green d-flex align-items-center gap-2" style="text-decoration:none; border-radius:12px; padding:10px 22px;">
        <i class="bi bi-plus-lg"></i> Lokasyon Ekle
    </a>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-geo-alt-fill" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">@Model.Count</div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Toplam Lokasyon</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-globe2" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">@Model.Select(x => x.Country).Distinct().Count()</div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Ülke</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-building" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">@Model.Select(x => x.City).Distinct().Count()</div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Şehir</div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-pin-map-fill" style="color:var(--green);"></i>
            <span>Tüm Lokasyonlar</span>
        </div>
        <span class="badge-green">@Model.Count kayıt</span>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="padding:14px 20px;">#</th>
                            <th style="padding:14px 20px;">Ülke</th>
                            <th style="padding:14px 20px;">Şehir</th>
                            <th style="padding:14px 20px;">Bölge</th>
                            <th style="padding:14px 20px;">Harita Önizleme</th>
                            <th style="padding:14px 20px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom:1px solid var(--border);">
                                <td style="padding:14px 20px; color:var(--text-muted); font-size:13px; font-weight:600;">@i</td>
                                <td style="padding:14px 20px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:34px;height:34px;background:var(--green-lt);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="bi bi-geo-alt-fill" style="color:var(--green);font-size:14px;"></i>
                                        </div>
                                        <span style="font-weight:600;color:var(--text-main);">@item.Country</span>
                                    </div>
                                </td>
                                <td style="padding:14px 20px;color:var(--text-muted);font-size:14px;">@item.City</td>
                                <td style="padding:14px 20px;">
                                    <span class="badge-green">@item.Region</span>
                                </td>
                                <td style="padding:14px 20px;">
                                    <img src="@item.MapLocationImageUrl" alt="harita"
                                         style="width:84px;height:52px;object-fit:cover;border-radius:10px;box-shadow:var(--shadow-sm);border:1.5px solid var(--border);" />
                                </td>
                                <td style="padding:14px 20px;">
                                    <div class="d-flex gap-2">
                                        <a href="/Location/UpdateLocation/@item.LocationId"
                                           class="topbar-icon-btn"
                                           style="width:34px;height:34px;border-radius:8px;background:var(--green-lt);border-color:var(--green-mid);color:var(--green-dk);"
                                           title="Düzenle">
                                            <i class="bi bi-pencil-fill" style="font-size:13px;"></i>
                                        </a>
                                        <a href="/Location/DeleteLocation/@item.LocationId"
                                           class="topbar-icon-btn"
                                           style="width:34px;height:34px;border-radius:8px;background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.2);color:var(--danger);"
                                           title="Sil"
                                           onclick="return confirm('Bu lokasyonu silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill" style="font-size:13px;"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5" style="color:var(--text-muted);">
                <div style="width:72px;height:72px;background:var(--green-lt);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                    <i class="bi bi-geo-alt" style="font-size:32px;color:var(--green);"></i>
                </div>
                <h6 style="font-weight:600;color:var(--text-main);">Lokasyon bulunamadı</h6>
                <p style="font-size:13px;margin-bottom:20px;">İlk lokasyonunuzu ekleyerek başlayın.</p>
                <a href="/Location/CreateLocation" class="btn-green" style="text-decoration:none;border-radius:10px;padding:9px 22px;">
                    <i class="bi bi-plus-lg me-1"></i> Lokasyon Ekle
                </a>
            </div>
        }
    </div>
</div>
