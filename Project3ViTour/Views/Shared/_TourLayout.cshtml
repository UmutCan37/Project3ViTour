@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ViTour Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fraunces:ital,wght@0,600;1,400&display=swap" rel="stylesheet" />

    <style>
        :root {
            --sidebar-w: 265px;
            --sidebar-collapsed-w: 70px;
            --green: #2ecc71;
            --green-dk: #27ae60;
            --green-lt: #eafaf1;
            --green-mid: #d5f5e3;
            --dark: #111b11;
            --surface: #f7fdf9;
            --white: #ffffff;
            --border: #e3f2e9;
            --text-main: #1a2e1a;
            --text-muted: #7a9c7a;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --shadow-sm: 0 1px 4px rgba(46,204,113,.08);
            --shadow-md: 0 4px 20px rgba(46,204,113,.12);
            --shadow-lg: 0 10px 40px rgba(46,204,113,.16);
            --sidebar-transition: 0.28s cubic-bezier(.4,0,.2,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            margin: 0;
            min-height: 100vh;
            display: flex;
        }

        a {
            text-decoration: none;
        }

        /* ───── SIDEBAR ───── */
        #sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: var(--sidebar-w);
            background: var(--white);
            border-right: 1.5px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 1050;
            transition: width var(--sidebar-transition);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

            #sidebar.collapsed {
                width: var(--sidebar-collapsed-w);
            }

        /* Brand */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 20px 18px;
            border-bottom: 1.5px solid var(--border);
            min-height: 72px;
            white-space: nowrap;
            overflow: hidden;
        }

        .brand-icon {
            flex-shrink: 0;
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--green), var(--green-dk));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            color: #fff;
            box-shadow: 0 4px 12px rgba(46,204,113,.35);
        }

        .brand-text {
            opacity: 1;
            transition: opacity .2s;
        }

        #sidebar.collapsed .brand-text {
            opacity: 0;
            pointer-events: none;
        }

        .brand-name {
            font-family: 'Fraunces', serif;
            font-size: 18px;
            color: var(--dark);
            line-height: 1.1;
            display: block;
        }

        .brand-sub {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: var(--text-muted);
            display: block;
            margin-top: 2px;
        }

        /* Nav */
        .sidebar-nav {
            flex: 1;
            padding: 14px 12px;
            overflow-y: auto;
            overflow-x: hidden;
        }

            .sidebar-nav::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-nav::-webkit-scrollbar-thumb {
                background: var(--green-mid);
                border-radius: 4px;
            }

        .nav-section-label {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: var(--text-muted);
            padding: 14px 10px 6px;
            white-space: nowrap;
            transition: opacity .2s;
        }

        #sidebar.collapsed .nav-section-label {
            opacity: 0;
        }

        .nav-item-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 12px;
            border-radius: 12px;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: all .18s;
            margin-bottom: 2px;
            position: relative;
        }

            .nav-item-link i {
                flex-shrink: 0;
                font-size: 17px;
                width: 22px;
                text-align: center;
            }

            .nav-item-link:hover {
                background: var(--green-lt);
                color: var(--green-dk);
            }

            .nav-item-link.active {
                background: linear-gradient(135deg, var(--green), var(--green-dk));
                color: #fff;
                box-shadow: var(--shadow-md);
            }

                .nav-item-link.active i {
                    color: #fff;
                }

        .nav-label {
            transition: opacity .2s, width .28s;
        }

        #sidebar.collapsed .nav-label {
            opacity: 0;
            width: 0;
            overflow: hidden;
        }

        /* Badge */
        .nav-badge {
            margin-left: auto;
            background: var(--green-lt);
            color: var(--green-dk);
            font-size: 11px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            transition: opacity .2s;
        }

        .nav-item-link.active .nav-badge {
            background: rgba(255,255,255,.25);
            color: #fff;
        }

        #sidebar.collapsed .nav-badge {
            opacity: 0;
        }

        /* Footer */
        .sidebar-footer {
            padding: 12px;
            border-top: 1.5px solid var(--border);
        }

        /* ───── MAIN ───── */
        #main-wrapper {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left var(--sidebar-transition);
        }

            #main-wrapper.expanded {
                margin-left: var(--sidebar-collapsed-w);
            }

        /* Topbar */
        #topbar {
            position: sticky;
            top: 0;
            z-index: 1040;
            height: 72px;
            background: var(--white);
            border-bottom: 1.5px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 28px;
            gap: 16px;
            box-shadow: var(--shadow-sm);
        }

        .btn-toggle-sidebar {
            background: none;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            cursor: pointer;
            transition: all .15s;
            flex-shrink: 0;
        }

            .btn-toggle-sidebar:hover {
                background: var(--green-lt);
                border-color: var(--green);
                color: var(--green-dk);
            }

        .topbar-search {
            flex: 1;
            max-width: 360px;
            position: relative;
        }

            .topbar-search input {
                width: 100%;
                padding: 10px 16px 10px 42px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--surface);
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 13.5px;
                color: var(--text-main);
                transition: all .15s;
                outline: none;
            }

                .topbar-search input:focus {
                    border-color: var(--green);
                    box-shadow: 0 0 0 3px rgba(46,204,113,.15);
                    background: #fff;
                }

            .topbar-search .search-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 15px;
                pointer-events: none;
            }

        .topbar-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .topbar-icon-btn {
            width: 40px;
            height: 40px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            background: none;
            color: var(--text-muted);
            font-size: 17px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            transition: all .15s;
        }

            .topbar-icon-btn:hover {
                background: var(--green-lt);
                border-color: var(--green);
                color: var(--green-dk);
            }

        .notif-badge {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 8px;
            height: 8px;
            background: var(--danger);
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .topbar-divider {
            width: 1px;
            height: 30px;
            background: var(--border);
            margin: 0 6px;
        }

        .admin-profile-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 12px 6px 6px;
            border: 1.5px solid var(--border);
            border-radius: 14px;
            background: none;
            cursor: pointer;
            transition: all .15s;
        }

            .admin-profile-btn:hover {
                background: var(--green-lt);
                border-color: var(--green);
            }

        .admin-avatar {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--green), var(--green-dk));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            box-shadow: 0 2px 8px rgba(46,204,113,.3);
        }

        .admin-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            line-height: 1.2;
        }

        .admin-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* Content */
        #content-area {
            flex: 1;
            padding: 28px 28px 40px;
        }

        .page-header {
            margin-bottom: 24px;
        }

        .page-title {
            font-family: 'Fraunces', serif;
            font-size: 26px;
            color: var(--dark);
            margin: 0 0 4px;
        }

        .breadcrumb {
            font-size: 12.5px;
            margin: 0;
        }

        .breadcrumb-item + .breadcrumb-item::before {
            color: var(--text-muted);
        }

        /* Genel card stili */
        .card {
            border: 1.5px solid var(--border) !important;
            border-radius: 16px !important;
            box-shadow: var(--shadow-sm) !important;
        }

        .card-header {
            background: var(--white) !important;
            border-bottom: 1.5px solid var(--border) !important;
            border-radius: 16px 16px 0 0 !important;
            padding: 16px 20px !important;
            font-weight: 600;
        }

        /* Buton stili */
        .btn-green {
            background: linear-gradient(135deg, var(--green), var(--green-dk));
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 9px 20px;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 4px 12px rgba(46,204,113,.3);
            transition: all .2s;
        }

            .btn-green:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(46,204,113,.4);
                color: #fff;
            }

        /* Tablo stili */
        .table th {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            background: var(--surface);
            border-bottom: 1.5px solid var(--border) !important;
        }

        .table td {
            vertical-align: middle;
            font-size: 14px;
        }

        .badge-green {
            background: var(--green-lt);
            color: var(--green-dk);
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        /* Dropdown */
        .dropdown-menu {
            border: 1.5px solid var(--border) !important;
            border-radius: 14px !important;
            box-shadow: var(--shadow-lg) !important;
            padding: 8px !important;
        }

        .dropdown-item {
            border-radius: 8px;
            font-size: 13.5px;
            padding: 9px 12px;
            transition: background .15s;
        }

            .dropdown-item:hover {
                background: var(--green-lt);
                color: var(--green-dk);
            }

        /* Mobil */
        @@media (max-width: 991.98px) {
            #sidebar {
                transform: translateX(-100%);
                transition: transform var(--sidebar-transition), width var(--sidebar-transition);
            }

                #sidebar.mobile-open {
                    transform: translateX(0);
                    width: var(--sidebar-w) !important;
                }

            #main-wrapper {
                margin-left: 0 !important;
            }

            #sidebar-backdrop {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,.3);
                z-index: 1049;
            }

                #sidebar-backdrop.show {
                    display: block;
                }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <aside id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-compass-fill"></i></div>
            <div class="brand-text">
                <span class="brand-name">ViTour</span>
                <span class="brand-sub">Yönetim Paneli</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Ana Menü</div>

            <a href="/Dashboard/Index" class="nav-item-link">
                <i class="bi bi-grid-1x2-fill"></i>
                <span class="nav-label">Dashboard</span>
            </a>

            <a href="/AdminTour/TourList" class="nav-item-link">
                <i class="bi bi-map-fill"></i>
                <span class="nav-label">Turlar</span>
            </a>

            <a href="/Booking/Index" class="nav-item-link">
                <i class="bi bi-calendar2-check-fill"></i>
                <span class="nav-label">Rezervasyonlar</span>
            </a>

            <a href="/Category/CategoryList" class="nav-item-link">
                <i class="bi bi-tag-fill"></i>
                <span class="nav-label">Kategoriler</span>
            </a>

            <a href="/Location/Index" class="nav-item-link">
                <i class="bi bi-geo-alt-fill"></i>
                <span class="nav-label">Lokasyonlar</span>
            </a>

            <a href="/GalleryImage/Index" class="nav-item-link">
                <i class="bi bi-images"></i>
                <span class="nav-label">Galeri</span>
            </a>

            <a href="/Review/ReviewList" class="nav-item-link">
                <i class="bi bi-star-fill"></i>
                <span class="nav-label">Yorumlar</span>
            </a>

            <a href="/TourPlanning/Index" class="nav-item-link">
                <i class="bi bi-journal-text"></i>
                <span class="nav-label">Tur Planları</span>
            </a>

            <div class="nav-section-label">Sistem</div>

            <a href="/admin/settings" class="nav-item-link">
                <i class="bi bi-gear-fill"></i>
                <span class="nav-label">Ayarlar</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/account/logout" class="nav-item-link" style="color: var(--danger);">
                <i class="bi bi-box-arrow-left" style="color:var(--danger);"></i>
                <span class="nav-label">Çıkış Yap</span>
            </a>
        </div>
    </aside>

    <div id="sidebar-backdrop"></div>

    <div id="main-wrapper">
        <header id="topbar">
            <button class="btn-toggle-sidebar" id="btnToggleSidebar" aria-label="Menüyü aç/kapat">
                <i class="bi bi-layout-sidebar-inset"></i>
            </button>

            <div class="topbar-search d-none d-md-block">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Ara..." />
            </div>

            <div class="topbar-actions">
                <button class="topbar-icon-btn d-md-none">
                    <i class="bi bi-search"></i>
                </button>

                <button class="topbar-icon-btn">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notif-badge"></span>
                </button>

                <button class="topbar-icon-btn d-none d-sm-flex">
                    <i class="bi bi-chat-dots-fill"></i>
                </button>

                <div class="topbar-divider d-none d-sm-block"></div>

                <div class="dropdown">
                    <button class="admin-profile-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="admin-avatar">A</div>
                        <div class="admin-info d-none d-sm-block">
                            <div class="admin-name">Admin</div>
                            <div class="admin-role">Süper Admin</div>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end mt-2" style="min-width:200px;">
                        <li>
                            <a class="dropdown-item" href="/admin/profile">
                                <i class="bi bi-person-circle me-2" style="color:var(--green)"></i> Profilim
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/admin/settings">
                                <i class="bi bi-gear me-2" style="color:var(--green)"></i> Ayarlar
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" style="border-color:var(--border);" /></li>
                        <li>
                            <a class="dropdown-item text-danger" href="/account/logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main id="content-area">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar   = document.getElementById('sidebar');
        const wrapper   = document.getElementById('main-wrapper');
        const backdrop  = document.getElementById('sidebar-backdrop');
        const btnToggle = document.getElementById('btnToggleSidebar');

        function isMobile() { return window.innerWidth < 992; }

        btnToggle.addEventListener('click', () => {
            if (isMobile()) {
                sidebar.classList.toggle('mobile-open');
                backdrop.classList.toggle('show');
            } else {
                sidebar.classList.toggle('collapsed');
                wrapper.classList.toggle('expanded');
            }
        });

        backdrop.addEventListener('click', () => {
            sidebar.classList.remove('mobile-open');
            backdrop.classList.remove('show');
        });

        // Aktif menü
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.nav-item-link').forEach(link => {
            const href = link.getAttribute('href')?.toLowerCase();
            if (href && currentPath.startsWith(href) && href !== '/') {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
