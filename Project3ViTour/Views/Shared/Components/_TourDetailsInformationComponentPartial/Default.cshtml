@using Project3ViTour.Dtos.TourDtos
@using Project3ViTour.Dtos.GalleryImageDtos
@model GetTourByIdDto
@inject Microsoft.Extensions.Localization.IStringLocalizer<Project3ViTour.Resources.SharedResource> L

<div class="tab-pane fade show active" id="pills-information" role="tabpanel"
     aria-labelledby="pills-information-tab" tabindex="0">
    <div class="row mb-50">
        <div class="col-lg-12">
            <div class="inner-heading-wrap flex-two">
                <div class="inner-heading">
                    <span class="feature">@Model.Badge</span>
                    <h2 class="title">@Model.Title</h2>
                    <ul class="flex-three list-wrap-heading">
                        <li class="flex-three">
                            <i class="icon-time-left"></i>
                            <span>@Model.DayCount @L["Detail_Days"]</span>
                        </li>
                        <li class="flex-three">
                            <i class="icon-user"></i>
                            <span>@L["Detail_MaxGuests"]: @Model.Capacity</span>
                        </li>
                    </ul>
                </div>
                <div class="inner-price">
                    <div class="flex-three">
                        <div class="start">
                            <i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i>
                        </div>
                        <span class="review">(0 @L["TourList_Reviews"])</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @{
        var images = ViewBag.GalleryImages as List<ResultGalleryImageDto>;
    }
    <div class="row mb-40 image-gallery-single">
        @if (images != null && images.Count > 0)
        {
            <div class="col-12 col-sm-6"><img src="@images[0].ImageUrl" alt="@images[0].Title"></div>
            @if (images.Count > 1)
            {
                <div class="col-6 col-sm-3"><img src="@images[1].ImageUrl" alt="@images[1].Title"></div>
            }
            @if (images.Count > 2)
            {
                <div class="col-6 col-sm-3"><img src="@images[2].ImageUrl" alt="@images[2].Title"></div>
            }
        }
        else
        {
            <div class="col-12 col-sm-6"><img src="@Model.CoverImageUrl" alt="@Model.Title"></div>
        }
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="information-content-tour">
                <div class="description-wrap mb-40">
                    <span class="description">@L["Detail_Description"]:</span>
                    <p class="des">@Model.Description</p>
                </div>
                <div class="description-wrap mb-40">
                    <span class="description">@L["Detail_AdvancedFeatures"]</span>
                    <p class="des">@L["Detail_AdvancedFeaturesText"]</p>
                </div>
                <div class="description-wrap mb-40">
                    <span class="description">@L["Detail_WhatToExpect"]</span>
                    <p class="des mb-18">@L["Detail_WhatToExpectText"]</p>
                    <ul class="listing-des">
                        <li><p>@L["Detail_Expect1"]</p></li>
                        <li><p>@L["Detail_Expect2"]</p></li>
                        <li><p>@L["Detail_Expect3"]</p></li>
                        <li><p>@L["Detail_Expect4"]</p></li>
                    </ul>
                </div>
                <div class="expect-wrap mb-70">
                    <h4 class="title mb-18">@L["Detail_TripDetails"]</h4>
                    <div class="expect flex-three"><span>@L["Detail_DepartureReturn"]</span><p>2 Taijichang St, Dongcheng Qu, Pekin, Çin</p></div>
                    <div class="expect flex-three"><span>@L["Detail_DepartureTime"]</span><p>@L["Detail_DepartureTimeText"]</p></div>
                    <div class="expect flex-three"><span>@L["Detail_ReturnTime"]</span><p>@L["Detail_ReturnTimeText"]</p></div>
                </div>
                <div class="expect-wrap mb-70">
                    <h4 class="title mb-40">@L["Detail_IncludedExcluded"]</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="listing-clude">
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include1"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include2"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include3"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include4"]</p></li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="listing-clude">
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include1"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include2"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include3"]</p></li>
                                <li class="flex-three"><i class="icon-Vector-7"></i><p>@L["Detail_Include4"]</p></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="expect-wrap">
                    <h4 class="title mb-40">@L["Detail_TourAmenities"]</h4>
                    <div class="row">
                        <div class="col-md-4">
                            <ul class="listing-icon">
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity1"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity2"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity3"]</p></li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <ul class="listing-icon">
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity4"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity5"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity6"]</p></li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <ul class="listing-icon">
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity7"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity8"]</p></li>
                                <li class="flex-three"><i class="icon-10"></i><p>@L["Detail_Amenity9"]</p></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="side-bar-right">
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookTour"]</h6>
                    <form action="/" id="form-book-tour">
                        <div class="input-wrap mb-30"><input type="date"></div>
                        <div class="flex-two mb-30">
                            <span class="label">@L["Detail_Time"]:</span>
                            <div class="radio">
                                <input id="first" type="radio" name="numbers" value="first" checked>
                                <label for="first">14.00</label>
                                <input id="second" type="radio" name="numbers" value="second">
                                <label for="second">16.00</label>
                            </div>
                        </div>
                        <div class="flex-two mb-40">
                            <span class="label">@L["TourList_Price"]:</span>
                            <span class="total text-main">₺@Model.Price</span>
                        </div>
                        <button type="submit">@L["Detail_ProceedBooking"]</button>
                    </form>
                </div>
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookWithConfidence"]</h6>
                    <ul class="category-confidence">
                        <li class="flex-three"><i class="icon-customer-service-1"></i><span>@L["Detail_CustomerCare"]</span></li>
                        <li class="flex-three"><i class="icon-Vector-6"></i><span>@L["Detail_HandpickedTours"]</span></li>
                        <li class="flex-three"><i class="icon-insurance-1"></i><span>@L["Detail_FreeInsurance"]</span></li>
                        <li class="flex-three"><i class="icon-price-tag-1-1"></i><span>@L["Detail_BestPrice"]</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
