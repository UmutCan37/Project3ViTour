@model List<Project3ViTour.Dtos.ReviewDtos.ResultReviewDto>
@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

@section Styles {
    <style>
        .search-wrap {
            position: relative;
        }

            .search-wrap i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 14px;
                pointer-events: none;
            }

            .search-wrap input {
                border-radius: 10px;
                border: 1.5px solid var(--border);
                background: var(--surface);
                padding: 9px 14px 9px 38px;
                font-size: 13.5px;
                font-family: 'Plus Jakarta Sans', sans-serif;
                transition: all .15s;
                outline: none;
                width: 260px;
            }

                .search-wrap input:focus {
                    border-color: var(--green);
                    box-shadow: 0 0 0 3px rgba(46,204,113,.12);
                    background: #fff;
                }

        .star-filled {
            color: #f59e0b;
        }

        .star-empty {
            color: var(--border);
        }

        .action-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1.5px solid transparent;
            font-size: 13px;
            cursor: pointer;
            transition: all .15s;
            text-decoration: none;
        }

        .action-btn-detail {
            background: var(--green-lt);
            border-color: var(--green-mid);
            color: var(--green-dk);
        }

            .action-btn-detail:hover {
                background: var(--green-mid);
                color: var(--green-dk);
            }

        .action-btn-del {
            background: rgba(239,68,68,.07);
            border-color: rgba(239,68,68,.2);
            color: var(--danger);
        }

            .action-btn-del:hover {
                background: rgba(239,68,68,.15);
            }
    </style>
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1 class="page-title">Yorumlar</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Dashboard/Index" style="color:var(--green);">Dashboard</a></li>
                <li class="breadcrumb-item active">Yorumlar</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-star-fill" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">@(Model?.Count ?? 0)</div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Toplam Yorum</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-check-circle-fill" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">@(Model?.Count(x => x.Status) ?? 0)</div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Aktif</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card p-3 d-flex flex-row align-items-center gap-3">
            <div style="width:46px;height:46px;background:var(--green-lt);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-bar-chart-fill" style="color:var(--green);font-size:20px;"></i>
            </div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--dark);">
                    @(Model != null && Model.Any() ? Model.Average(x => x.Score).ToString("0.0") : "—")
                </div>
                <div style="font-size:12px;color:var(--text-muted);font-weight:500;">Ortalama Puan</div>
            </div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-star-fill" style="color:var(--green);"></i>
            <span>Tüm Yorumlar</span>
            <span class="badge-green">@(Model?.Count ?? 0) kayıt</span>
        </div>
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input id="tableSearch" type="text" placeholder="Müşteri veya yorum ara…" />
        </div>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5" style="color:var(--text-muted);">
                <div style="width:72px;height:72px;background:var(--green-lt);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                    <i class="bi bi-star" style="font-size:32px;color:var(--green);"></i>
                </div>
                <h6 style="font-weight:600;color:var(--text-main);">Henüz yorum yok</h6>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="reviewTable">
                    <thead>
                        <tr>
                            <th style="padding:14px 20px;">#</th>
                            <th style="padding:14px 20px;">Müşteri</th>
                            <th style="padding:14px 20px;">Tur</th>
                            <th style="padding:14px 20px;">Yorum</th>
                            <th style="padding:14px 20px;">Puan</th>
                            <th style="padding:14px 20px;">Tarih</th>
                            <th style="padding:14px 20px;">Durum</th>
                            <th style="padding:14px 20px; text-align:right;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                        }
                        @foreach (var item in Model.OrderByDescending(x => x.ReviewDate))
                        {
                            <tr class="data-row" style="border-bottom:1px solid var(--border);">
                                <td style="padding:13px 20px;color:var(--text-muted);font-size:13px;font-weight:600;">@i</td>
                                <td style="padding:13px 20px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:34px;height:34px;background:var(--green-lt);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                            <i class="bi bi-person-fill" style="color:var(--green);font-size:14px;"></i>
                                        </div>
                                        <span style="font-weight:600;color:var(--text-main);font-size:14px;">@item.NameSurname</span>
                                    </div>
                                </td>
                                <td style="padding:13px 20px;">
                                    <span class="badge-green">
                                        @(ViewBag.Tours != null && ((Dictionary<string, string>)ViewBag.Tours).ContainsKey(item.TourId.ToString())
                                            ? ((Dictionary<string, string>)ViewBag.Tours)[item.TourId.ToString()]
                                            : item.TourId.ToString())
                                    </span>
                                </td>
                                <td style="padding:13px 20px;max-width:220px;">
                                    <div style="font-size:13px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @item.Detail
                                    </div>
                                </td>
                                <td style="padding:13px 20px;">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <i class="bi bi-star-fill @(s <= item.Score ? "star-filled" : "star-empty")" style="font-size:12px;"></i>
                                    }
                                </td>
                                <td style="padding:13px 20px;">
                                    <span style="background:var(--surface);border:1.5px solid var(--border);border-radius:999px;padding:4px 10px;font-size:12px;color:var(--text-muted);">
                                        @item.ReviewDate.ToString("dd.MM.yyyy")
                                    </span>
                                </td>
                                <td style="padding:13px 20px;">
                                    @if (item.Status)
                                    {
                                        <span class="badge-green"><i class="bi bi-check-circle-fill me-1"></i>Aktif</span>
                                    }
                                    else
                                    {
                                        <span style="background:rgba(239,68,68,.08);color:var(--danger);padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;border:1.5px solid rgba(239,68,68,.2);">
                                            <i class="bi bi-x-circle-fill me-1"></i>Pasif
                                        </span>
                                    }
                                </td>
                                <td style="padding:13px 20px;text-align:right;">
                                    <div class="d-inline-flex gap-2">
                                        <button class="action-btn action-btn-detail" type="button"
                                                data-bs-toggle="modal" data-bs-target="#detailModal"
                                                data-name="@item.NameSurname"
                                                data-tour="@(ViewBag.Tours != null && ((Dictionary<string, string>)ViewBag.Tours).ContainsKey(item.TourId.ToString()) ? ((Dictionary<string, string>)ViewBag.Tours)[item.TourId.ToString()] : item.TourId.ToString())"
                                                data-detail="@item.Detail"
                                                data-score="@item.Score"
                                                data-date="@item.ReviewDate.ToString("dd.MM.yyyy")"
                                                data-status="@item.Status.ToString().ToLower()"
                                                title="Detay">
                                            <i class="bi bi-eye-fill"></i>
                                        </button>
                                        <button class="action-btn action-btn-del" type="button"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                data-id="@item.ReviewId"
                                                data-name="@item.NameSurname"
                                                title="Sil">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius:16px;border:1.5px solid var(--border);box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1.5px solid var(--border);padding:18px 24px;">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:38px;height:38px;background:var(--green-lt);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-star-fill" style="color:var(--green);font-size:15px;"></i>
                    </div>
                    <h5 class="modal-title mb-0" style="font-weight:700;color:var(--dark);">Yorum Detayı</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:14px 16px;">
                            <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-weight:700;margin-bottom:6px;">Müşteri</div>
                            <div style="font-weight:700;color:var(--text-main);font-size:15px;" id="d-name">—</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div style="background:var(--green-lt);border:1.5px solid var(--green-mid);border-radius:12px;padding:14px 16px;">
                            <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-weight:700;margin-bottom:6px;">Tur</div>
                            <div style="font-weight:700;color:var(--green-dk);font-size:14px;" id="d-tour">—</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:14px 16px;">
                            <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-weight:700;margin-bottom:8px;">Puan</div>
                            <div id="d-stars"></div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:14px 16px;">
                            <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-weight:700;margin-bottom:6px;">Tarih / Durum</div>
                            <div style="font-size:13px;color:var(--text-main);font-weight:600;" id="d-date">—</div>
                            <div id="d-status" class="mt-1"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:16px;">
                            <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-weight:700;margin-bottom:10px;">Yorum</div>
                            <div style="font-size:14px;color:var(--text-main);line-height:1.7;" id="d-detail">—</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1.5px solid var(--border);padding:14px 24px;">
                <button type="button" class="btn" style="border-radius:10px;padding:9px 22px;border:1.5px solid var(--border);color:var(--text-muted);font-weight:600;font-size:14px;" data-bs-dismiss="modal">
                    Kapat
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:1.5px solid var(--border);box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="border-bottom:1.5px solid var(--border);padding:18px 24px;">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:38px;height:38px;background:rgba(239,68,68,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-trash-fill" style="color:var(--danger);font-size:15px;"></i>
                    </div>
                    <h5 class="modal-title mb-0" style="font-weight:700;color:var(--dark);">Yorumu Sil</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-muted);font-size:14px;margin-bottom:12px;">Bu işlem geri alınamaz. Silmek istediğiniz yorum:</p>
                <div style="background:var(--surface);border:1.5px solid var(--border);border-radius:10px;padding:10px 14px;font-size:13px;color:var(--text-main);font-weight:600;">
                    <i class="bi bi-person-fill me-2" style="color:var(--green);"></i>
                    <span id="deleteNameText">—</span>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1.5px solid var(--border);padding:14px 24px;gap:8px;">
                <button type="button" class="btn" style="border-radius:10px;padding:9px 20px;border:1.5px solid var(--border);color:var(--text-muted);font-weight:600;font-size:14px;" data-bs-dismiss="modal">
                    Vazgeç
                </button>
                <a id="btnConfirmDelete" href="#" class="btn"
                   style="border-radius:10px;padding:9px 20px;background:var(--danger);color:#fff;font-weight:600;font-size:14px;border:none;">
                    <i class="bi bi-trash-fill me-1"></i> Sil
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Arama
        document.getElementById('tableSearch')?.addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            document.querySelectorAll('#reviewTable tbody tr.data-row').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none';
            });
        });

        // Detail Modal
        document.getElementById('detailModal')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('d-name').textContent    = btn.dataset.name   || '—';
            document.getElementById('d-tour').textContent    = btn.dataset.tour   || '—';
            document.getElementById('d-detail').textContent  = btn.dataset.detail || '—';
            document.getElementById('d-date').textContent    = btn.dataset.date   || '—';

            // Stars
            const score = parseInt(btn.dataset.score) || 0;
            let stars = '';
            for (let s = 1; s <= 5; s++) {
                stars += `<i class="bi bi-star-fill" style="font-size:18px; color:${s <= score ? '#f59e0b' : 'var(--border)'}; margin-right:2px;"></i>`;
            }
            document.getElementById('d-stars').innerHTML = stars;

            // Status
            const isActive = btn.dataset.status === 'true';
            document.getElementById('d-status').innerHTML = isActive
                ? `<span style="color:var(--green-dk);font-size:12px;font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Aktif</span>`
                : `<span style="color:var(--danger);font-size:12px;font-weight:600;"><i class="bi bi-x-circle-fill me-1"></i>Pasif</span>`;
        });

        // Delete Modal
        document.getElementById('deleteModal')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('deleteNameText').textContent = btn.dataset.name || '—';
            document.getElementById('btnConfirmDelete').href = '/Review/DeleteReview/' + btn.dataset.id;
        });
    </script>
}
