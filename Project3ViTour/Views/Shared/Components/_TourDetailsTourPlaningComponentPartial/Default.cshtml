@using Project3ViTour.Dtos.TourPlanningDtos
@model List<ResultTourPlanningDto>
@inject Microsoft.Extensions.Localization.IStringLocalizer<Project3ViTour.Resources.SharedResource> L

<div class="tab-pane fade" id="pills-tour-planing" role="tabpanel"
     aria-labelledby="pills-tour-planing-tab" tabindex="0">
    <div class="row">
        <div class="col-lg-8">
            <div class="planing-content-tour">
                <h3 class="title-plan">@L["Detail_TourPlan"] :</h3>
                @foreach (var item in Model)
                {
                    <div class="tour-planing-section flex">
                        <div class="number-box flex-five">@item.DayNumber.ToString("D2")</div>
                        <div class="content-box">
                            <h5 class="title">@item.DayTitle</h5>
                            <p class="des">@item.Description</p>
                            @if (!string.IsNullOrEmpty(item.Activities))
                            {
                                <ul class="listing-des mt-10">
                                    @foreach (var activity in item.Activities.Split(','))
                                    {
                                        <li><p>@activity.Trim()</p></li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <div class="side-bar-right">
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookTour"]</h6>
                    <form action="/" id="form-book-tour">
                        <div class="input-wrap mb-30"><input type="date"></div>
                        <div class="flex-two mb-30">
                            <span class="label">Saat:</span>
                            <div class="radio">
                                <input id="first" type="radio" name="numbers" value="first" checked>
                                <label for="first">14.00</label>
                                <input id="second" type="radio" name="numbers" value="second">
                                <label for="second">16.00</label>
                            </div>
                        </div>
                        <div class="flex-two mb-40">
                            <span class="label">Toplam:</span>
                            <span class="total text-main">₺0.00</span>
                        </div>
                        <button type="submit">@L["Detail_ProceedBooking"]</button>
                    </form>
                </div>
                <div class="sidebar-widget">
                    <h6 class="block-heading">@L["Detail_BookWithConfidence"]</h6>
                    <ul class="category-confidence">
                        <li class="flex-three"><i class="icon-customer-service-1"></i><span>@L["Detail_CustomerCare"]</span></li>
                        <li class="flex-three"><i class="icon-Vector-6"></i><span>@L["Detail_HandpickedTours"]</span></li>
                        <li class="flex-three"><i class="icon-insurance-1"></i><span>@L["Detail_FreeInsurance"]</span></li>
                        <li class="flex-three"><i class="icon-price-tag-1-1"></i><span>@L["Detail_BestPrice"]</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
