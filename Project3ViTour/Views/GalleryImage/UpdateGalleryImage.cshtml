@model GetGalleryImageByIdDto
@{
    ViewData["Title"] = "UpdateGalleryImage";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}






@section Styles {
    <style>
        .card-surface {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: var(--shadow-sm);
        }

        .btn-accent {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            border-radius: 12px;
            padding: 10px 14px;
            font-weight: 600;
        }

            .btn-accent:hover {
                background: var(--accent-dk);
                border-color: var(--accent-dk);
                color: #fff;
            }

        .btn-soft {
            border-radius: 12px;
            padding: 10px 14px;
            font-weight: 600;
        }

        .form-control, .form-select {
            border-radius: 12px;
            border-color: var(--border);
            background: var(--surface);
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(45,156,219,.15);
                background: #fff;
            }

        .label-muted {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: .3px;
        }

        .hint {
            font-size: 12.5px;
            color: var(--text-muted);
        }

        .preview-box {
            border: 1px solid var(--border);
            border-radius: 16px;
            background: linear-gradient(180deg, #fff, #fbfcff);
            padding: 14px;
        }

        .preview-img {
            width: 100%;
            max-height: 260px;
            object-fit: cover;
            border-radius: 14px;
            border: 1px solid var(--border);
            background: var(--surface);
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--surface);
            font-size: 12px;
            color: var(--text-muted);
            max-width: 100%;
        }

            .pill code {
                font-size: 11.5px;
                color: var(--navy);
                background: transparent;
                padding: 0;
            }
    </style>
}

<div class="page-header">
    <h1 class="page-title">Update Gallery Image</h1>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin" class="text-decoration-none">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/GalleryImage/Index" class="text-decoration-none">Gallery Images</a></li>
            <li class="breadcrumb-item active" aria-current="page">Update</li>
        </ol>
    </nav>
</div>

<div class="card-surface p-3 p-md-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="pill">
                <i class="bi bi-hash"></i>
                ImageId: <code>@Model.GalleryImageId</code>
            </span>
            <div class="hint">Alanları güncelle — ImageUrl değiştikçe sağda canlı önizleme güncellenir.</div>
        </div>

        <a href="/GalleryImage/Index" class="btn btn-outline-secondary btn-soft">
            <i class="bi bi-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>

    <form asp-controller="GalleryImage" asp-action="UpdateGalleryImage" method="post">
        @Html.AntiForgeryToken()

        <!-- Id gitmezse update çalışmaz -->
        <input type="hidden" asp-for="GalleryImageId" />

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="mb-3">
                    <label class="label-muted mb-1">Title</label>
                    <input class="form-control" asp-for="Title" />
                </div>

                <div class="mb-3">
                    <label class="label-muted mb-1">ImageUrl</label>
                    <input class="form-control" asp-for="ImageUrl" id="imageUrlInput" placeholder="https://..." />
                    <div class="form-text hint">Doğrudan resim linki olmalı (örn: .jpg/.png).</div>
                </div>

                <div class="mb-3">
                    <label class="label-muted mb-1">Tour</label>

                    @* Eğer controller ViewBag.Tours gönderiyorsa dropdown *@
                    @if (ViewBag.Tours != null)
                    {
                        <select class="form-select" asp-for="TourId" asp-items="ViewBag.Tours">
                            <option value="">— Tur Seç —</option>
                        </select>
                    }
                    else
                    {
                        <input class="form-control" asp-for="TourId" />
                    }
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-accent">
                        <i class="bi bi-check2-circle me-1"></i> Güncelle
                    </button>

                    <a href="/GalleryImage/Index" class="btn btn-outline-secondary btn-soft">
                        Vazgeç
                    </a>

                    <a href="/GalleryImage/DeleteGalleryImage/@Model.GalleryImageId"
                       class="btn btn-outline-danger btn-soft ms-auto"
                       onclick="return confirm('Bu görseli silmek istediğine emin misin?');">
                        <i class="bi bi-trash3 me-1"></i> Sil
                    </a>
                </div>
            </div>

            <!-- ✅ PREVIEW -->
            <div class="col-lg-5">
                <div class="preview-box">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="label-muted">Preview</div>
                        <a class="btn btn-sm btn-outline-secondary btn-soft" style="padding:6px 10px;"
                           href="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "#" : Model.ImageUrl)"
                           id="openImageBtn" target="_blank" rel="noopener">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Aç
                        </a>
                    </div>

                    <img id="imagePreview"
                         class="preview-img"
                         src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://via.placeholder.com/1200x700?text=Image+Preview" : Model.ImageUrl)"
                         alt="Preview" />

                    <div class="hint mt-2">
                        URL hatalıysa placeholder’a döner.
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // asp-for bazen id'yi "ImageUrl" üretir; ikisini de yakalayalım
        const urlInput =
            document.getElementById('imageUrlInput') ||
            document.getElementById('ImageUrl');

        const preview = document.getElementById('imagePreview');
        const openBtn = document.getElementById('openImageBtn');

        function setPreview(url) {
            const fallback = 'https://via.placeholder.com/1200x700?text=Image+Preview';

            if (!preview || !openBtn) return;

            if (!url || url.trim().length < 5) {
                preview.src = fallback;
                openBtn.href = '#';
                return;
            }

            preview.src = url;
            openBtn.href = url;
        }

        if (urlInput) {
            // sayfa ilk açılışta mevcut url'yi de bas
            setPreview(urlInput.value);

            // değiştikçe güncelle
            urlInput.addEventListener('input', () => setPreview(urlInput.value));
        }

        preview?.addEventListener('error', () => {
            preview.src = 'https://via.placeholder.com/1200x700?text=Invalid+URL';
            openBtn.href = '#';
        });
    </script>
}

